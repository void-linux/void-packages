 3 files changed, 14 insertions(+), 3 deletions(-)

diff --git a/src/omemo/crypto.h b/src/omemo/crypto.h
index 313fcf4ac166..8bca9794e299 100644
--- a/src/omemo/crypto.h
+++ b/src/omemo/crypto.h
@@ -8,7 +8,14 @@
