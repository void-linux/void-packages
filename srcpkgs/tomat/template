post_install() {
	vlicense LICENSE

	for _f in target/man/*.1; do
		vman "$_f"
	done

	vcompletion target/completions/tomat.bash bash
	vcompletion target/completions/tomat.fish fish
	vcompletion target/completions/_tomat zsh
}
