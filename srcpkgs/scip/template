# Template file for 'scip'
pkgname=scip
version=10.0.2
revision=1
build_style=cmake
configure_args="-DCMAKE_BUILD_TYPE=Release -DAUTOBUILD=ON -DLTO=ON -DSYM=bliss -DBUILD_TESTING=ON"
hostmakedepends="cmake ninja"
makedepends="boost-devel zlib-devel readline-devel libstdc++-devel gmp-devel tbb-devel mpfr-devel bliss-devel libsoplex-devel papilo-devel"
short_desc="Solving Constraint Integer Programs"
maintainer="Heitor <heitorleite@dcc.ufmg.br>"
license="Apache-2.0"
homepage="https://scipopt.org"
distfiles="https://github.com/scipopt/scip/archive/refs/tags/v${version}.tar.gz"
checksum=685eb4db00ed9106b29d7e0ab1c41d78b5e4366ac66ce1a11fb3f8baa507ef20

if [ -z "$XBPS_CHECK_PKGS" ]; then
	configure_args+=" -DBUILD_TESTING=OFF"
fi

do_check() {
	cd build
	ctest
}

libscip_package() {
	short_desc+=" - runtime library"
	pkg_install() {
		vmove "usr/lib/*.so.*"
	}
}

libscip-devel_package() {
	depends="libscip>=${version}_${revision} scip>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/cmake
		vmove "usr/lib/*.so"
	}
}
