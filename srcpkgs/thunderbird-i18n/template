# Template file for 'thunderbird-i18n'
pkgname=thunderbird-i18n
version=128.3.1
revision=1
build_style=meta
short_desc="Thunderbird language packs"
maintainer="dataCobra <datacobra@thinkbot.de>"
license="MPL-2.0"
homepage="https://www.thunderbird.net/"

create_wrksrc=yes

do_extract() {
	:
}

