do_install() {
	vmkdir usr/src/${pkgname}-${version}
	cp -r * $DESTDIR/usr/src/${pkgname}-${version}
	vcopy ${FILESDIR}/dkms.conf usr/src/${pkgname}-${version}
	vlicense LICENSES/preferred/MIT
}
