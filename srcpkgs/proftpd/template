conf_files="/etc/proftpd.conf"

if [ "$XBPS_TARGET_LIBC" = "glibc" ]; then
	makedepends+=" libxcrypt-devel"
fi

proftpd-devel_package() {
	short_desc+=" - development files"
	depends="proftpd>=${version}_${revision}"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
	}
}
