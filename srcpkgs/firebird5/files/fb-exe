#!/bin/sh
[ -z "$_FBEXE_" ] || exit 231
export _FBEXE_=1

_link_name="${0##*/}"
_exe=${_link_name#*-} # prefix-name -> name
_wrapper="$(readlink -f $0)"
_dir_wrapper=${_wrapper%/*}
_fb_root="${_dir_wrapper%/*}"
_fb_root_lib="$_fb_root/lib"

show(){
echo "_link_name=$_link_name"
echo "_wrapper=$_wrapper"
echo "_exe=$_exe"
echo "_dir_wrapper=$_dir_wrapper"
echo "_fb_root=$_fb_root"
echo "_fb_root_lib=$_fb_root_lib"
exit 222
}

[ "$_FBEXE_SHOWONLY_" ] && show

export LD_LIBRARY_PATH="$_fb_root_lib:$LD_LIBRARY_PATH"
export FIREBIRD_MSG="$_fb_root/lib/msg"
export PATH="$_dir_wrapper:$PATH"
#exec "$_dir_wrapper/$_exe" "$@"
exec "$_exe" "$@"
