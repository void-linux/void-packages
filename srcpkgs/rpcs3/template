# Template file for 'rpcs3'
pkgname=rpcs3
version=0.0.40.19083
revision=1
_commit=5a90dc005969218aa05b4cfdf7cd24d3aa259986
build_style=cmake
configure_args="-DUSE_NATIVE_INSTRUCTIONS=OFF -DCHECK_FOR_UPDATE=OFF
 -DUSE_SYSTEM_CURL=ON -DUSE_SYSTEM_ZLIB=ON -DUSE_SYSTEM_LIBUSB=OFF
 -DUSE_SYSTEM_SDL=ON -DUSE_SYSTEM_FFMPEG=OFF -DBUILD_LLVM=ON
 -DUSE_SYSTEM_OPENAL=ON -DUSE_SYSTEM_OPENCV=ON -DUSE_SYSTEM_PUGIXML=OFF
 -DUSE_SYSTEM_FAUDIO=OFF -DUSE_LTO=ON -DSHM_DIR=/dev/shm"
hostmakedepends="pkg-config cmake python3 git which"
makedepends="qt6-base-devel qt6-multimedia-devel qt6-svg-devel
 libopenal-devel libcurl-devel libevdev-devel eudev-libudev-devel
 SDL3-devel glew-devel libX11-devel libXext-devel libXrandr-devel
 libXi-devel libXcursor-devel libXinerama-devel vulkan-loader-devel
 Vulkan-Headers wayland-devel libxkbcommon-devel alsa-lib-devel
 zlib-devel libzstd-devel libxml2-devel pulseaudio-devel
 jack-devel sndio-devel libXmu-devel libXaw-devel libusb-devel
 hidapi-devel miniupnpc-devel pugixml-devel rtmidi-devel
 libprotobuf-devel libgamemode-devel libXScrnSaver-devel
 libXfixes-devel libdecor-devel icu-devel"
short_desc="Open-source Sony PlayStation 3 emulator"
maintainer="User <user@example.com>"
license="GPL-2.0-only"
homepage="https://rpcs3.net/"
distfiles="https://github.com/RPCS3/rpcs3/archive/${_commit}.tar.gz"
checksum=7777777777777777777777777777777777777777777777777777777777777777

# NOTE: RPCS3 requires recursive submodules which are not in the tarball.
# GitHub tarballs do not include submodules. This template is a draft.

post_patch() {
	# disable git versioning
	vsed -e 's|find_package(Git)|# &|' -i git-version.cmake 2>/dev/null || true
}

do_install() {
	vbin build/bin/rpcs3
	vinstall rpcs3/rpcs3.desktop 644 usr/share/applications
	vinstall rpcs3/rpcs3.svg 644 usr/share/pixmaps
	vmkdir usr/share/rpcs3
	vcopy build/bin/GuiConfigs usr/share/rpcs3/
	vcopy build/bin/Icons usr/share/rpcs3/
}
