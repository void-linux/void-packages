# Template file for 'ghcup-hs'
pkgname=ghcup-hs
version=0.2.5.0
revision=1
archs="~i686" # cborg failing to build on i686
build_style=cabal
build_helper="qemu"
cabal_index_state="2026-05-26T10:17:10Z"
hostmakedepends="ghc cabal-install pkg-config"
makedepends="libffi-devel ncurses-devel zlib-devel bzip2-devel openssl-devel
 liblzma-devel libarchive-devel"
short_desc="Haskell toolchain installer"
maintainer="rayfadh <rayfadh@duck.com>"
license="LGPL-3.0-only"
homepage="https://www.haskell.org/ghcup/"
changelog="https://raw.githubusercontent.com/haskell/ghcup-hs/master/CHANGELOG.md"
distfiles="https://github.com/haskell/ghcup-hs/archive/v${version}.tar.gz"
checksum=e6fbf2a58f9e0ba64fd5565ae8b25eaf3ac8f2f745fea6c295661d2c94f78e75
lib32depends="libffi-devel>=0 ncurses-devel>=0 zlib-devel>=0 bzip2-devel>=0
 openssl-devel>=0 xz>=0 libarchive-devel>=0"
nocross=yes
nopie_files="/usr/bin/ghcup"

post_configure() {
	printf 'package libarchive\n    flags: +system-libarchive\n' >> cabal.project.local
	printf 'constraints: xz +system-xz\n' >> cabal.project.local
}

post_install() {
	for _shell in bash zsh; do
			vtargetrun ${DESTDIR}/usr/bin/ghcup \
					--${_shell}-completion-script /usr/bin/ghcup \
					> ghcup.${_shell}
			vcompletion ghcup.${_shell} ${_shell}
	done
}
