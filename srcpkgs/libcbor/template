# Template file for 'libcbor'
pkgname=libcbor
version=0.14.0
revision=1
build_style=cmake
configure_args="-DBUILD_SHARED_LIBS=ON"
short_desc="Library for parsing and generating CBOR, a binary data format"
maintainer="Leah Neukirchen <leah@vuxu.org>"
license="MIT"
homepage="https://github.com/PJK/libcbor"
distfiles="https://github.com/PJK/libcbor/archive/v${version}.tar.gz"
checksum=a8c1516e741562cf95aa4479c64916c3d4d2623e24fdc35e414e2320e7300aae

post_install() {
	vlicense LICENSE.md
}

libcbor-devel_package() {
	depends="libcbor>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/cmake
		vmove usr/lib/pkgconfig
		vmove "usr/lib/*.so"
	}
}
