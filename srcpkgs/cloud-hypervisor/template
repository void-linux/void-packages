do_install() {
	for f in cloud-hypervisor ch-remote; do
		for b in target/*/release/$f; do
			vbin $b
		done
	done
	vbin scripts/ch-trace-visualiser.py ch-trace-visualiser

	for f in LICENSES/*; do
		vlicense $f
	done
}
