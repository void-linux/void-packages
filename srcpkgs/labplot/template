# Template file for 'labplot'
pkgname=labplot
version=2.12.1
revision=1
build_style=cmake
configure_args="-DENABLE_CANTOR=OFF -DENABLE_MQTT=OFF -DENABLE_READSTAT=OFF"
hostmakedepends="extra-cmake-modules gettext pkg-config bison qt6-base qt6-tools kf6-kconfig kf6-kdoctools"
makedepends="qt6-tools-devel qt-advanced-docking-system-devel kf6-kdoctools-devel kf6-karchive-devel kf6-kcompletion-devel kf6-kconfig-devel kf6-kconfigwidgets-devel kf6-kcoreaddons-devel kf6-kcrash-devel kf6-ki18n-devel kf6-kiconthemes-devel kf6-kio-devel kf6-kparts-devel kf6-kservice-devel kf6-ktextwidgets-devel kf6-kwidgetsaddons-devel kf6-knewstuff-devel kf6-purpose-devel kf6-kuserfeedback-devel kf6-syntax-highlighting-devel gsl-devel fftw-devel hdf5-devel netcdf-devel cfitsio-devel eigen poppler-qt6-devel libzstd-devel liblz4-devel"
short_desc="Interactive graphing and analysis of scientific data"
maintainer="orahcio <orahcio@gmail.com>"
license="GPL-2.0-or-later, GPL-3.0-or-later"
homepage="https://labplot.kde.org"
changelog="https://invent.kde.org/education/labplot/-/raw/master/ChangeLog?ref_type=heads"
distfiles="${KDE_SITE}/${pkgname}/${pkgname}-${version}.tar.xz"
checksum=e28155bfddf40e5b6f7c4791313556d1e48138044f216f210d515b9f6d6c106a
CFLAGS="-D_GNU_SOURCE ${CFLAGS}"

case "$XBPS_TARGET_MACHINE" in
	*-musl) makedepends+=" libexecinfo-devel" ;;
esac

do_check() {
	# Multiple tests fail on i686, likely due to floating point precision differences
	cd build
	case "$XBPS_TARGET_MACHINE" in
		i686*)
			;;
		*)
			ctest ${makejobs} --output-on-failure -E "(FitTest|ParserTest|DatapickerTest)"
			;;
	esac
}
