make_dirs="/etc/ananicy.d 0755 root root"

if [ "$XBPS_TARGET_LIBC" = musl ]; then
	makedepends+=" libexecinfo-devel"
	configure_args+=" -DCMAKE_CXX_STANDARD_LIBRARIES=-lexecinfo"
fi

post_install() {
	vsv ananicy-cpp
}
