pluma-devel_package() {
	depends="${sourcepkg}-${version}_${revision} gtksourceview4-devel libpeas-devel"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove usr/share/gtk-doc
		vmove usr/share/gir-1.0
	}
}
