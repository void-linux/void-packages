# Template file for 'marble5'
pkgname=marble5
version=24.08.3
revision=1
build_style=cmake
configure_args="-DBUILD_MARBLE_TESTS=NO -DBUILD_MARBLE_APPS=NO
 -DWITH_DESIGNER_PLUGIN=NO
 -DMARBLE_PLUGIN_PATH=/usr/lib/marble-qt5/plugins"
hostmakedepends="extra-cmake-modules perl qt5-host-tools qt5-qmake gettext
 qt5-tools kcoreaddons"
makedepends="gpsd-devel phonon-qt5-devel qt5-svg-devel
 qt5-plugin-mysql qt5-plugin-odbc qt5-plugin-pgsql qt5-plugin-sqlite
 qt5-plugin-tds qt5-webchannel-devel kio-devel qt5-declarative-devel
 qt5-location-devel qt5-serialport-devel qt5-webkit-devel shapelib-devel
 protobuf-devel"
depends="marble6"
short_desc="Virtual globe and world atlas"
maintainer="Piotr Wójcik <chocimier@tlen.pl>"
license="LGPL-2.1-or-later, GFDL-1.2-only"
homepage="https://marble.kde.org"
changelog="https://kde.org/announcements/changelogs/gear/${version}/#marble"
distfiles="${KDE_SITE}/release-service/${version}/src/marble-${version}.tar.xz"
checksum=c53c1faa741e1b424594c2021fa4edc620528e862ceff280cb3c952d1af20371

if [ "$XBPS_TARGET_WORDSIZE" = "$XBPS_WORDSIZE" ]; then
	makedepends+=" qt5-webengine-devel"
fi

post_patch() {
	vsed -i CMakeLists.txt -e 's/-Wcast-align//'
	vsed -i doc/CMakeLists.txt -e 's/macro_optional_find/return()#&/'
	vsed -i tests/CMakeLists.txt -e "s!@@WRKSRC@@!$wrksrc!"
}

marble5-devel_package() {
	short_desc+=" - development files"
	depends="${makedepends} ${sourcepkg}>=${version}_${revision}"
	replaces="marble-devel>=0"
	provides="marble-devel-${version}_${revision}"
	pkg_install() {
		vmove usr/include
		vmove "usr/lib/*.so"
		vmove usr/lib/cmake
		vmove usr/lib/qt5/mkspecs
	}
}
