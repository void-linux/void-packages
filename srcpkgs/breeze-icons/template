# Template file for 'breeze-icons'
pkgname=breeze-icons
version=6.25.0
revision=1
build_style=cmake
configure_args="-DINSTALL_HOST_TOOLS=ON"
hostmakedepends="extra-cmake-modules qt6-base qt6-tools python3-lxml libxml2"
makedepends="qt6-base-devel"
checkdepends="fdupes"
short_desc="Breeze icon theme"
maintainer="John <me@johnnynator.dev>"
license="LGPL-3.0-or-later"
homepage="https://community.kde.org/Frameworks"
distfiles="${KDE_SITE}/frameworks/${version%.*}/${pkgname}-${version}.tar.xz"
checksum=2188492d83ead80cae83cbb0db80cac0b55388ea2e3e02d436354b6ca2559d0c
nostrip=yes

if [ -z "$CROSS_BUILD" ]; then
	configure_args+=" -DBINARY_ICONS_RESOURCE=ON"
else
	hostmakedepends+=" libbreeze-icons-devel"
	configure_args+=" -DBINARY_ICONS_RESOURCE=OFF"
fi

libbreeze-icons_package() {
	pkg_install() {
		vmove "usr/lib/*.so.*"
	}
}

libbreeze-icons-devel_package() {
	depends="libbreeze-icons>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		if [ -z "$CROSS_BUILD" ]; then
			vmove usr/bin
		fi
		vmove usr/include
		vmove usr/lib/cmake
		vmove "usr/lib/*.so"
	}
}
