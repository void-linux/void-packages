# Template file for 'libpisp'
pkgname=libpisp
version=1.4.0
revision=1
build_style=meson
hostmakedepends="pkg-config"
makedepends="json-c++"
short_desc="Helper library for Raspberry Pi ISP (PiSP) configuration"
maintainer="Rutpiv <roger_freitas@live.com>"
license="BSD-2-Clause"
homepage="https://github.com/raspberrypi/libpisp"
distfiles="https://github.com/raspberrypi/libpisp/archive/v${version}.tar.gz"
checksum=314c6caea5c753f4b353df131d8b8626b70bfa38b76d8658698918cc0f7c1614

post_install() {
	vlicense LICENSE
}

libpisp-devel_package() {
	depends="libpisp-${version}_${revision} json-c++"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove "usr/lib/*.so"
	}
}
