do_install() {
	vmkdir /opt/dwarffortress
	vcopy "*" /opt/dwarffortress
	chmod 755 "${DESTDIR}"/opt/dwarffortress/{dwarfort,run_df,*.so*}

	vbin ${FILESDIR}/dwarffortress
	vlicense readme.txt dwarffortress.txt
}
