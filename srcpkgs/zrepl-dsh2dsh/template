# Template file for 'zrepl'
pkgname=zrepl-dsh2dsh
version=1.2.1
revision=2
build_style=go
go_import_path=github.com/dsh2dsh/zrepl
go_ldflags="-X github.com/dsh2dsh/zrepl/version.zreplVersion=void-${version}_${revision}"
depends="zfs"
short_desc="Fork of zrepl by dsh2dsh"
maintainer="Aaron Duxler <aaron@duxler.at>"
license="MIT"
homepage="https://github.com/dsh2dsh/zrepl"
distfiles="https://github.com/dsh2dsh/zrepl/archive/v${version}.tar.gz"
conflicts="zrepl>=0"
checksum=0c802cd09bef92671095dcc3b77b573ff26aa09a578c0068512de9c206da38dc

conf_files="/etc/zrepl/*"

post_install() {
	vmkdir etc/zrepl
	vinstall ${FILESDIR}/zrepl.yml 644 etc/zrepl
	vsconf ${FILESDIR}/zrepl.yml
	vcopy internal/config/samples/* usr/share/examples/${pkgname}
	vsconf dist/grafana/grafana-prometheus-zrepl.json

	vlicense LICENSE
	vsv zrepl
}
