# Template file for 'libcdr'
pkgname=libcdr
version=0.1.9
revision=1
build_style=gnu-configure
configure_args="--disable-debug"
hostmakedepends="pkg-config"
makedepends="lcms2-devel icu-devel librevenge-devel boost-headers
 libcppunit-devel zlib-devel"
short_desc="Corel Draw file format importer library"
maintainer="Đoàn Trần Công Danh <congdanhqx@gmail.com>"
license="MPL-2.0"
homepage="https://wiki.documentfoundation.org/DLP/Libraries/libcdr"
distfiles="http://dev-www.libreoffice.org/src/libcdr/${pkgname}-${version}.tar.xz"
checksum=f7bb6abdd7f226820f288a93dd8d07759833c0250d9e202af90f9b312c4665a3

libcdr-devel_package() {
	depends="libcdr>=${version}_${revision} librevenge-devel lcms2-devel icu-devel
	 zlib-devel"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove "usr/lib/*.so"
	}
}

libcdr-tools_package() {
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/bin
	}
}
