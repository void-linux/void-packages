# NOTE: DuckStation requires submodules. This is a draft.

do_install() {
	vbin build/bin/duckstation-qt duckstation
	vinstall scripts/appimage/org.duckstation.DuckStation.desktop 644 usr/share/applications duckstation.desktop
	vinstall scripts/appimage/org.duckstation.DuckStation.png 644 usr/share/pixmaps duckstation.png
	vmkdir usr/share/duckstation
	vcopy bin/database usr/share/duckstation/
	vcopy bin/resources usr/share/duckstation/
	vcopy bin/translations usr/share/duckstation/
}
