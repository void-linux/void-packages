post_install() {
	# use system tz database
	rm -rf ${DESTDIR}/${py3_sitelib}/pytz/zoneinfo
	ln -sf /usr/share/zoneinfo ${DESTDIR}/${py3_sitelib}/pytz/zoneinfo
	vlicense LICENSE.txt LICENSE
}
