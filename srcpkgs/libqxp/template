# Template file for 'libqxp'
pkgname=libqxp
version=0.0.3
revision=1
build_style=gnu-configure
hostmakedepends="pkg-config"
makedepends="boost-headers librevenge-devel icu-devel libcppunit-devel"
short_desc="Parser for QuarkXPress file format documents"
maintainer="Đoàn Trần Công Danh <congdanhqx@gmail.com>"
license="MPL-2.0"
homepage="https://wiki.documentfoundation.org/DLP/Libraries/libqxp"
distfiles="https://dev-www.libreoffice.org/src/${pkgname}/${pkgname}-${version}.tar.xz"
checksum=4687a9cc96c32d7406e5072c4da150fca696c563e5cde62b024f82fa53d32332

libqxp-tools_package() {
	short_desc+=" - tools"
	depends="${sourcepkg}>=${version}_${revision}"
	pkg_install() {
		vmove usr/bin
	}
}

libqxp-devel_package() {
	short_desc+=" - development files"
	depends="${sourcepkg}>=${version}_${revision} librevenge-devel"
	pkg_install() {
		vmove "usr/lib/*.so"
		vmove usr/lib/pkgconfig
		vmove usr/include
	}
}
