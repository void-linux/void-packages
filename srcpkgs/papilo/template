# Template file for 'papilo'
pkgname=papilo
version=3.0.0
revision=1
build_style=cmake
hostmakedepends="cmake ninja"
makedepends="libgcc-devel boost-devel tbb-devel gmp-devel blas-devel"
short_desc="Parallel Presolve for Integer and Linear Optimization"
maintainer="Heitor <heitorleite@dcc.ufmg.br>"
license="Apache-2.0"
homepage="https://scipopt.org"
distfiles="https://github.com/scipopt/papilo/archive/refs/tags/v${version}.tar.gz"
checksum=04e2437c41404782fa31cd74a881b475d75a6e692e4c88a24bf48cf5d263a93d

if [ -z "$XBPS_CHECK_PKGS" ]; then
	configure_args+=" -DBUILD_TESTING=OFF"
fi

papilo-devel_package() {
	depends="${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/cmake
		vmove "usr/lib/*.a"
	}
}
