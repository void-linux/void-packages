# Template file for 'nudoku'
pkgname=nudoku
version=6.0.0
revision=1
build_style=gnu-configure
hostmakedepends="automake pkg-config"
makedepends="ncurses-devel gettext-devel"
short_desc="Ncurses based sudoku game"
maintainer="Orphaned <orphan@voidlinux.org>"
license="GPL-3.0-or-later"
homepage="https://github.com/jubalh/nudoku"
distfiles="https://github.com/jubalh/${pkgname}/archive/${version}.tar.gz"
checksum=98a80a58a15ea664dfa62e1e5ae51c737f9555ef114e483f3b3c2674d9c51495

case "$XBPS_TARGET_MACHINE" in
	aarch64*|arm*) hostmakedepends+=" gettext-tiny";;
esac

if [ "$XBPS_TARGET_LIBC" = "musl" ]; then
	configure_args+=" --disable-nls"
fi

pre_configure() {
	# void uses gettext 0.22.5
	sed -i 's/0.20.0/0.22.5/' configure.ac
	autoreconf -i
}
