post_install() {
	mv ${DESTDIR}/usr/share/bash-completion/completions/cppman{.bash,}
	rm ${DESTDIR}/usr/share/zsh/vendor-completions/_cppman
	vcompletion misc/completions/zsh/_cppman zsh
}
