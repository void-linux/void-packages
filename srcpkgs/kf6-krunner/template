# Template file for 'kf6-krunner'
pkgname=kf6-krunner
version=6.24.0
revision=1
build_style=cmake
hostmakedepends="extra-cmake-modules qt6-tools qt6-base
 kf6-kconfig gettext"
makedepends="kf6-kconfig-devel kf6-kcoreaddons-devel kf6-ki18n-devel
 kf6-kitemmodels-devel kf6-kwindowsystem-devel"
checkdepends="dbus"
short_desc="Framework for providing different actions given a string query"
maintainer="John <me@johnnynator.dev>"
license="LGPL-2.1-or-later"
homepage="https://invent.kde.org/frameworks/krunner"
distfiles="${KDE_SITE}/frameworks/${version%.*}/${pkgname#kf6-}-${version}.tar.xz"
checksum=5775d7292a31c0ca339b385c18f3716fda5486317423c53809a10d8008ff8e4d

do_check() {
	cd build
	dbus-run-session ctest
}

kf6-krunner-devel_package() {
	depends="${makedepends//private-} ${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/cmake
		vmove "usr/lib/*.so"
	}
}
