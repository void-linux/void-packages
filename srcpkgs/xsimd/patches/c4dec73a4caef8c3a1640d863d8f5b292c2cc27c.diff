+#elif XSIMD_WITH_VSX
+                __asm__ volatile("" : "+wa"(x));
+#else
+                __asm__ volatile("" : : "r"(&x) : "memory");
+#endif
+#else
+                __asm__ volatile("" : : "r"(&x) : "memory");
+#endif
+#else
+                (void)x;
+#endif
