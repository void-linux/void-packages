# Template file for 'virglrenderer'
pkgname=virglrenderer
version=1.3.0
revision=1
build_style=meson
hostmakedepends="pkg-config python3-yaml"
makedepends="libepoxy-devel MesaLib-devel"
short_desc="Virgl GL renderer library"
maintainer="Orphaned <orphan@voidlinux.org>"
license="MIT"
homepage="https://gitlab.freedesktop.org/virgl/virglrenderer"
distfiles="https://gitlab.freedesktop.org/virgl/virglrenderer/-/archive/${version}/virglrenderer-${version}.tar.gz"
checksum=065bc56e89e6f631f96101cd62eba0748e48eb888b434edc86e89d05395e76f3

post_install() {
	vlicense COPYING
}

virglrenderer-devel_package() {
	short_desc+=" - development files"
	depends="${makedepends} ${sourcepkg}>=${version}_${revision}"
	pkg_install() {
		vmove usr/include
		vmove "usr/lib/*.so"
		vmove usr/lib/pkgconfig
	}
}
