# Template file for 'libdvdread'
pkgname=libdvdread
version=7.0.1
revision=1
build_style=meson
configure_args="-Dlibdvdcss=enabled"
hostmakedepends="pkg-config"
makedepends="libdvdcss-devel"
short_desc="DVD access library"
maintainer="Orphaned <orphan@voidlinux.org>"
license="GPL-2.0-or-later, LGPL-2.1-or-later"
homepage="https://www.videolan.org/developers/libdvdnav.html"
distfiles="https://get.videolan.org/libdvdread/${version}/libdvdread-${version}.tar.xz"
checksum=2e3e04a305c15c3963aa03ae1b9a83c1d239880003fcf3dde986d3943355d407

libdvdread-devel_package() {
	depends="${sourcepkg}>=${version}_${revision} libdvdcss-devel"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/share
		vmove usr/lib/pkgconfig
		vmove "usr/lib/*.so"
		vmove "usr/lib/*.a"
	}
}
