# Template file for 'wt'
pkgname=wt
version=4.13.3
revision=1
build_style=cmake
configure_args="-DBUILD_EXAMPLES=OFF"
makedepends="boost-devel-minimal libboost_thread libboost_filesystem
 libboost_program_options openssl-devel Haru-devel pango-devel sqlite-devel
 postgresql-libs-devel libmysqlclient-devel unixodbc-devel libfreeglut-devel
 libunwind-devel"
short_desc="Wt, C++ Web Toolkit"
maintainer="Orphaned <orphan@voidlinux.org>"
license="GPL-2.0-or-later"
homepage="https://www.webtoolkit.eu/wt"
changelog="https://webtoolkit.eu/wt/doc/reference/html/Releasenotes.html"
distfiles="https://github.com/emweb/wt/archive/refs/tags/${version}.tar.gz"
checksum=0fbfcc0154553b93e1f0bdffa86cc632e4ff21e13bef753f9e94dc50936a3abd

wt-devel_package() {
	depends="${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/cmake
		vmove "usr/lib/*.so"
	}
}
