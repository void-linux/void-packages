post_install() {
	vlicense COPYING
}

rist-utils_package() {
	short_desc+=" - utils"
	pkg_install() {
		vmove usr/bin
	}
}

librist-devel_package() {
	depends="${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove "usr/lib/*.so"
	}
}
