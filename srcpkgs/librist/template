build_style=meson
makedepends="mbedtls-devel"
short_desc="Reliable Internet Stream Transport (RIST)"
maintainer="Duncaen <duncaen@voidlinux.org>"
license="BSD-2-Clause"
homepage="https://code.videolan.org/rist/librist"
