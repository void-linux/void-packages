libde265-tools_package() {
	short_desc+=" - tools"
	pkg_install() {
		vmove usr/bin
	}
}

libde265-devel_package() {
	short_desc+=" - development files"
	depends="${sourcepkg}>=${version}_${revision}"
	pkg_install() {
		vmove usr/include
		vmove "usr/lib/*.so"
		vmove usr/lib/pkgconfig
	}
}
