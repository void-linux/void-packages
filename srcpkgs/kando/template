# Template file for 'kando'
pkgname=kando
version=2.3.1
revision=1
archs="x86_64 aarch64"
hostmakedepends="cmake pkg-config nodejs base-devel"
makedepends="libX11-devel libXtst-devel libxkbcommon-devel wayland-devel
 libxkbfile-devel libsecret-devel gobject-introspection"
depends="libX11 libXtst libxkbfile libsecret"
short_desc="Do things with utmost efficiency"
maintainer="zenobit <zen@osowoso.org>"
license="CC-BY-4.0, CC0-1.0, OFL-1.1, MIT"
homepage="https://kando.menu"
changelog="https://raw.githubusercontent.com/kando-menu/kando/refs/heads/main/docs/changelog.md"
distfiles="https://github.com/kando-menu/kando/archive/refs/tags/v${version}.tar.gz"
checksum=c63b1ffbc3c4a42dbe98e35dbc811cb62e67068c7227da3f631826842bef4a06

case "$XBPS_TARGET_MACHINE" in
	x86_64*) _electron_arch="x64" ;;
	aarch64*) _electron_arch="arm64" ;;
esac

do_configure() {
	export npm_config_fund=false
	export npm_config_audit=false
	npm install
}

do_build() {
	npm run package -- --arch ${_electron_arch}
}

do_install() {
	vmkdir usr/lib/kando
	vcopy out/Kando-linux-${_electron_arch}/* usr/lib/kando
	vinstall out/Kando-linux-${_electron_arch}/chrome-sandbox 4755 usr/lib/kando
	vbin "${FILESDIR}/kando"

	vmkdir usr/share/applications
	vcopy appstream/menu.kando.Kando.desktop usr/share/applications/kando.desktop

	vmkdir usr/share/icons
	vcopy assets/icons/* usr/share/icons

	for f in docs/*.md; do
		vdoc "$f"
	done

	vlicense LICENSES/MIT.txt
}
