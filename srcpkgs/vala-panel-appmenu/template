# Template file for 'vala-panel-appmenu'
pkgname=vala-panel-appmenu
version=25.04
revision=1
build_style=meson
build_helper="gir"
configure_args="-Dxfce=enabled -Dmate=disabled -Dbudgie=disabled
 -Dvalapanel=disabled -Dappmenu-gtk-module=enabled -Dregistrar=enabled
 -Djayatana=disabled"
hostmakedepends="pkg-config vala glib-devel gobject-introspection gettext"
makedepends="glib-devel libxkbcommon-devel libdbusmenu-glib-devel
 gdk-pixbuf-devel dconf-devel xfce4-panel-devel xfconf-devel libXt-devel
 libwnck-devel"
short_desc="Global Menu plugin for XFCE panel"
maintainer="John Eira <john.eira@web.de>"
license="LGPL-3.0-or-later"
homepage="https://gitlab.com/vala-panel-project/vala-panel-appmenu"
distfiles="https://gitlab.com/vala-panel-project/vala-panel-appmenu/-/archive/${version}/vala-panel-appmenu-${version}.tar.gz"
checksum=48d0be87b260056a65a9056a9be7e190b67a508540ebcb1fc18a67349cca0177

post_install() {
	vinstall "${FILESDIR}/80-appmenu-gtk-module.sh" 755 etc/X11/xinit/xinitrc.d
}

appmenu-glib-translator_package() {
	short_desc="Translate DBusMenu menus into GMenuModels"
	pkg_install() {
		vmove usr/lib/libappmenu-glib-translator*.so.*
		vmove usr/share/gir-1.0
		vmove usr/share/glib-2.0
		vmove usr/share/vala
	}
}
appmenu-glib-translator-devel_package() {
	short_desc+=" - development files"
	depends="appmenu-glib-translator-${version}_${revision}"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove "usr/lib/libappmenu-glib-translator*.so"
	}
}
vala-panel-appmenu-registrar_package() {
	short_desc="Small utility to hold DBusMenu menus"
	pkg_install() {
		vmove usr/libexec/vala-panel
		vmove usr/share/dbus-1
	}
}
vala-panel-appmenu-locale_package() {
	short_desc="Translations for vala-panel-appmenu"
	pkg_install() {
		vmove usr/share/locale
	}
}
appmenu-gtk3-module_package() {
	short_desc="GTK module for exposing menus over DBusMenu"
	depends="vala-panel-appmenu-registrar-${version}_${revision}"
	pkg_install() {
		vmove usr/lib/gtk-3.0
		vmove "usr/lib/libappmenu-gtk3*.so.*"
		vmove etc/X11/xinit/xinitrc.d/80-appmenu-gtk-module.sh
	}
}
vala-panel-appmenu-xfce_package() {
	short_desc="XFCE Panel applet for vala-panel-appmenu"
	depends="appmenu-glib-translator-${version}_${revision}
	 vala-panel-appmenu-registrar-${version}_${revision}
	 vala-panel-appmenu-locale-${version}_${revision}
	 appmenu-gtk3-module-${version}_${revision}"
	pkg_install() {
		vmove usr/lib/xfce4
		vmove usr/share/xfce4
	}
}
