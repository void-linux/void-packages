# Template file for 'claw-bin'
pkgname=claw-bin
version=1.5.2
revision=1
archs="x86_64"
short_desc="Crustacean powered clipboard manager for X11 and Wayland"
maintainer="Dustin Pilgrim <dustin.pilgrim1997@gmail.com>"
license="MIT"
homepage="https://github.com/saltnpepper97/claw"
distfiles="${homepage}/releases/download/v${version}/claw-${version}-linux-x86_64.tar.gz"
checksum=9d04392c14a3ad1e52221e58925c6691b34a059fccfdab6ce08ec178359b917a
nostrip=yes

skip_extraction="${distfiles##*/}"

do_extract() {
	mkdir -p "${wrksrc}"
	bsdtar -xzf "${XBPS_SRCDISTDIR}/${pkgname}-${version}/${distfiles##*/}" \
		--strip-components=1 -C "${wrksrc}"
}

do_install() {
	vbin bin/claw
	vmkdir usr/share/doc/${pkgname}
	vcopy examples/* usr/share/doc/${pkgname}
	vdoc README.md
	vlicense LICENSE
}
