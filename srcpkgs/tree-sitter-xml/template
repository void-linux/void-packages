# Template file for 'tree-sitter-xml'
pkgname=tree-sitter-xml
version=0.7.0
revision=1
build_wrksrc="xml"
build_style=tree-sitter
short_desc="XML grammar for tree-sitter"
maintainer="classabbyamp <void@placeviolette.net>"
license="MIT"
homepage="https://github.com/tree-sitter-grammars/tree-sitter-xml"
distfiles="https://github.com/tree-sitter-grammars/tree-sitter-xml/archive/refs/tags/v${version}.tar.gz"
checksum=4330a6b3685c2f66d108e1df0448eb40c468518c3a66f2c1607a924c262a3eb9

post_build() {
	cd "${wrksrc}/dtd"
	do_build
}

post_install() {
	cd "${wrksrc}/dtd"
	do_install

	vmkdir "usr/share/tree-sitter/queries"
	vcopy "${wrksrc}/queries/*" "usr/share/tree-sitter/queries"

	vlicense "${wrksrc}/LICENSE"
}
