# Template file for 'rgbds'
pkgname=rgbds
version=0.9.4
revision=1
build_style=gnu-makefile
hostmakedepends="bison pkg-config"
makedepends="libpng-devel"
depends="libpng"
short_desc="Free assembler/linker for the Game Boy and Game Boy Color"
maintainer="Chloe Greene <angel@angelwood.xyz>"
license="MIT"
homepage="https://rgbds.gbdev.io/"
distfiles="https://github.com/gbdev/rgbds/releases/download/v${version}/rgbds-source.tar.gz"
checksum=65b16d4eeb6f26afe42dac0fd8fa267bb7fd815a60c84955cc22afd527009101

#the makefile installer is buggy so we manually have to do this
do_install() {
	# binarys
	vbin rgbasm
	vbin rgbgfx
	vbin rgbfix
	vbin rgblink

	#manpages
	vman man/gbz80.7
	vman man/rgbasm.1
	vman man/rgbasm.5
	vman man/rgbasm-old.5
	vman man/rgbds.5
	vman man/rgbds.7
	vman man/rgbfix.1
	vman man/rgbgfx.1
	vman man/rgblink.1
	vman man/rgblink.5

	#licence
	vlicense LICENSE
}
