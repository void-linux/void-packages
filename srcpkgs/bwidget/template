# Template file for 'bwidget'
pkgname=bwidget
_tclversion=8.6
version=1.10.1
revision=1
makedepends="tk"
depends="tk"
short_desc="Set of extension widgets for Tcl/Tk"
maintainer="Orphaned <orphan@voidlinux.org>"
license="TCL"
homepage="https://core.tcl-lang.org/bwidget/home"
distfiles="${SOURCEFORGE_SITE}/tcllib/BWidget/${version}/${pkgname}-${version}.tar.gz"
checksum=4aea02f38cf92fa4aa44732d4ed98648df839e6537d6f0417c3fe18e1a34f880

do_install() {
	# default directories and files permissions are 0750, unusable for users
	find . -type f -exec chmod 0644 {} \;
	find . -type d -exec chmod 0755 {} \;

	vlicense LICENSE.txt

	vdoc README.txt
	vdoc CHANGES.txt
	vdoc ChangeLog
	vcopy BWman usr/share/doc/${pkgname}/BWman
	vcopy demo usr/share/doc/${pkgname}/demo

	vmkdir usr/lib/tcl${_tclversion}/BWidget

	vcopy "*.tcl" usr/lib/tcl${_tclversion}/BWidget
	vcopy images usr/lib/tcl${_tclversion}/BWidget
	vcopy lang usr/lib/tcl${_tclversion}/BWidget
}
