[main]
@type = classic
@version = @VERSION@
@description = "runit"
@user = (root)

[start]
@build = custom
@shebang = ( "/bin/sh" )
@execute = (
PATH=/usr/bin

runlevel=66

runsvchdir "${runlevel}"
s6-mkdir -v -p /run/runit/runsvdir
s6-ln -s /etc/runit/runsvdir/current /run/runit/runsvdir/current

exec s6-env -i PATH=$PATH \
    runsvdir -P /run/runit/runsvdir/current
 )

[stop]
@build = custom
@shebang = ( "/bin/sh" )
@execute = ( sv force-stop /var/service/* }
 sv exit /var/service/* )

[logger]
@backup = 3
@maxsize = 1000000
