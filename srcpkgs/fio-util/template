# Template file for 'fio-util'
pkgname=fio-util
version=3.2.16.1731
revision=1
archs="x86_64"
depends="pciutils lsof"
short_desc="SanDisk Fusion-io ioMemory userspace tools (VSL3)"
maintainer="Zoa Hickenlooper <zoa@router.sex>"
license="custom:Proprietary"
homepage="https://github.com/RemixVSL/iomemory-vsl"
_vsldlrev=0bca66ffc7a94d73db688012cb2bb73ab689d99d
distfiles="https://raw.githubusercontent.com/RemixVSL/vsl_downloads/${_vsldlrev}/vsl3/fio-util_${version}-1.0_amd64.deb"
checksum=5b4aa6b3624479f3c7c1dcdb17c6201c2c92d9563069ac52e1fa7f5dadc720bc
repository=nonfree
restricted=yes
nopie=yes

do_install() {
	# /usr/bin/* and /usr/share/man/man8/* and /usr/share/doc/*
	vcopy usr /

	# Relocate /etc/modprobe.d to /usr/lib/modprobe.d (Void policy)
	vinstall etc/modprobe.d/iomemory-vsl.conf 644 usr/lib/modprobe.d

	# Vendor ships udev rules at /lib/udev; relocate to /usr/lib/udev (Void convention)
	vinstall lib/udev/rules.d/95-fio.rules 644 usr/lib/udev/rules.d

	vlicense usr/share/doc/fio-util/copyright LICENSE
}
