# Template file for 'libmd'
pkgname=libmd
version=1.2.0
revision=1
build_style=gnu-configure
short_desc="Message Digest functions from BSD systems"
maintainer="Duncaen <duncaen@voidlinux.org>"
license="BSD-3-Clause, BSD-2-Clause, ISC, Beerware, custom:Public Domain"
homepage="https://www.hadrons.org/software/libmd/"
distfiles="https://archive.hadrons.org/software/libmd/libmd-${version}.tar.xz"
checksum=ac15ffb8430502fbaccdec66c5a82ee0eab0b0f36220df56710feadfeb13d0a0

post_install() {
	vlicense COPYING
}

libmd-devel_package() {
	depends="${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove "usr/lib/*.a"
		vmove "usr/lib/*.so"
		vmove usr/share
	}
}
