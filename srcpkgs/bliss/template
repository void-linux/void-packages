# Template file for 'bliss'
pkgname=bliss
version=0.77
revision=1
build_style=cmake
configure_args="-DUSE_GMP=OFF"
hostmakedepends="cmake ninja"
makedepends="libgcc-devel libstdc++-devel"
short_desc="Tool for computing canonical labelings and automorphism groups of graphs"
maintainer="Heitor <heitorleite@dcc.ufmg.br>"
license="GPL-3.0-only"
homepage="https://users.aalto.fi/~tjunttil/bliss"
distfiles="https://github.com/scipopt/bliss/archive/refs/tags/v${version}.tar.gz"
checksum=9af3d614d1a6e9649f055444d21d4e9d22fca0b69f072f10ea8f3e23d8479efd

bliss-devel_package() {
	depends="${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/cmake
		vmove "usr/lib/*.a"
	}
}
