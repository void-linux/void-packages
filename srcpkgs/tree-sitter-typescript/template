# Template file for 'tree-sitter-typescript'
pkgname=tree-sitter-typescript
version=0.23.2
revision=2
build_wrksrc="typescript"
build_style=tree-sitter
depends="tree-sitter-javascript"
short_desc="Typescript grammar for tree-sitter"
maintainer="classabbyamp <void@placeviolette.net>"
license="MIT"
homepage="https://github.com/tree-sitter/tree-sitter-typescript"
distfiles="https://github.com/tree-sitter/tree-sitter-typescript/archive/refs/tags/v${version}.tar.gz"
checksum=2c4ce711ae8d1218a3b2f899189298159d672870b5b34dff5d937bed2f3e8983

post_build() {
	cd "${wrksrc}/tsx"
	do_build
}

post_install() {
	cd "${wrksrc}/tsx"
	do_install

	vmkdir "usr/share/tree-sitter/queries/typescript"
	vcopy "${wrksrc}/queries/*.scm" "usr/share/tree-sitter/queries/typescript"
	ln -s typescript "${DESTDIR}/usr/share/tree-sitter/queries/tsx"
	vlicense "${wrksrc}/LICENSE"
}
