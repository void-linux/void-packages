if [ "$XBPS_TARGET_LIBC" = "musl" ]; then
	makedepends+=" musl-legacy-compat"
fi

post_extract() {
	sed -i 's/^\(LD\|CPP\)FLAGS/override &/' Makefile
	sed '/\*\//q' calmwm.c >LICENSE
}
post_install() {
	vlicense LICENSE
}
