# Template file for 'jsonnet'
pkgname=jsonnet
version=0.22.0
revision=1
build_style=cmake
build_helper="qemu"
configure_args="-DUSE_SYSTEM_GTEST=ON"
hostmakedepends="pkg-config help2man"
makedepends="gtest-devel"
short_desc="Data templating language"
maintainer="Leah Neukirchen <leah@vuxu.org>"
license="Apache-2.0"
homepage="https://github.com/google/jsonnet"
distfiles="https://github.com/google/jsonnet/archive/v${version}.tar.gz"
checksum=5914b9904d97efa662d919519cef1a14e4132bfddddaeed8b061b4a8af628f8d

CXXFLAGS="-fPIC"

if [ "$CROSS_BUILD" ]; then
	configure_args+=" -DBUILD_TESTS=OFF -DEXEC_WRAPPER=/usr/bin/qemu-${XBPS_TARGET_QEMU_MACHINE}"
fi

pre_configure() {
	if [ "$CROSS_BUILD" ]; then
		"$CXX_FOR_BUILD" -o to_c_array stdlib/to_c_array.cpp
		PATH="$PATH:$PWD"
	fi
}

jsonnet-devel_package() {
	depends="${sourcepkg}-${version}_${revision}"
	short_desc="${short_desc} - development files"
	pkg_install() {
		vmove usr/include
		vmove "usr/lib/*.a"
		vmove "usr/lib/*.so"
	}
}
