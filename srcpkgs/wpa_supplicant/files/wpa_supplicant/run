#!/bin/sh
if [ -r ./conf ]; then
	. ./conf
	: ${OPTS:=-M -c ${CONF_FILE:-/etc/wpa_supplicant/wpa_supplicant.conf} ${WPA_INTERFACE:+-i ${WPA_INTERFACE}} ${DRIVER:+-D ${DRIVER}}}
else
	. ./auto
	OPTS="${AUTO}"
fi

! [ -d /run/wpa_supplicant ] && install -m 0750 -g _wpas -o _wpas -d /run/wpa_supplicant

_caps=-all,+net_admin,+net_raw

exec 2>&1
exec setpriv --reuid _wpas --regid _wpas --clear-groups \
  --ambient-caps $_caps \
  --inh-caps $_caps \
  --bounding-set $_caps \
  --no-new-privs -- wpa_supplicant ${OPTS}
