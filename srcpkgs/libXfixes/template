# Template file for 'libXfixes'
pkgname=libXfixes
version=6.0.2
revision=1
build_style=gnu-configure
hostmakedepends="pkg-config"
makedepends="xorgproto libX11-devel"
short_desc="Xfixes library and extension of X RandR from modular X.org"
maintainer="Orphaned <orphan@voidlinux.org>"
license="MIT"
homepage="https://xorg.freedesktop.org"
distfiles="${XORG_SITE}/lib/libXfixes-${version}.tar.xz"
checksum=39f115d72d9c5f8111e4684164d3d68cc1fd21f9b27ff2401b08fddfc0f409ba

post_install() {
	vlicense COPYING
}

libXfixes-devel_package() {
	depends="${makedepends} ${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove "usr/lib/*.a"
		vmove "usr/lib/*.so"
		vmove usr/share
	}
}
