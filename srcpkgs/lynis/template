do_install() {
	vmkdir etc/lynis
	vinstall default.prf 0644 etc/lynis
	vmkdir usr/share/lynis
	vcopy include usr/share/lynis/
	vcopy plugins usr/share/lynis/
	vcopy db usr/share/lynis/
	vbin lynis
	vman lynis.8
	vdoc FAQ
	vcompletion extras/bash_completion.d/lynis bash
}
