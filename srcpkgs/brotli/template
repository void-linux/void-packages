# Template file for 'brotli'
pkgname=brotli
version=1.2.0
revision=2
build_style=cmake
configure_args="-DBROTLI_BUILD_FOR_PACKAGE=ON"
short_desc="Generic-purpose lossless compression algorithm"
maintainer="Leah Neukirchen <leah@vuxu.org>"
license="MIT"
homepage="https://github.com/google/brotli"
distfiles="https://github.com/google/${pkgname}/archive/v${version}.tar.gz"
checksum=816c96e8e8f193b40151dad7e8ff37b1221d019dbcb9c35cd3fadbfe6477dfec

post_install() {
	vlicense LICENSE

	# Drop the -static suffix from static libs
	for p in ${DESTDIR}/usr/lib/*-static.a; do
		mv -v ${p} ${p%-static.a}.a
	done
}

brotli-devel_package() {
	short_desc+=" - development files"
	depends="${sourcepkg}>=${version}_${revision}"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/*.so
		vmove usr/lib/*.a
		vmove usr/lib/pkgconfig
	}
}
