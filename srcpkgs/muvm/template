do_install() {
	vbin target/${XBPS_RUST_TARGET}/release/muvm
	vbin target/${XBPS_RUST_TARGET}/release/muvm-guest
	vbin target/${XBPS_RUST_TARGET}/release/muvm-server
}

post_install() {
	vlicense crates/muvm/LICENSE
}
