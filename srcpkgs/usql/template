do_check() {
	go test -p "${XBPS_MAKEJOBS}" -v -tags "${go_build_tags}" -ldflags "${go_ldflags}" \
		$(go list ./... | grep -v /drivers)
}

post_install() {
	vlicense LICENSE
}
