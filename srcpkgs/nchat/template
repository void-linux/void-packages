# Template file for 'nchat'
pkgname=nchat
version=5.13.17
revision=1
build_style=cmake
configure_args="-DCMAKE_BUILD_TYPE=None -DCMAKE_INSTALL_PREFIX=/usr -DCMAKE_INSTALL_MANDIR=/usr/share/man"
hostmakedepends="cmake go gperf ninja"
makedepends="ncurses-devel openssl-devel sqlite-devel zlib-devel file-devel"
short_desc="Console-based chat client with support for Telegram"
maintainer="Jaymz665 <jaymz665@gmail.com>"
license="MIT"
homepage="https://github.com/d99kris/nchat"
distfiles="https://github.com/d99kris/nchat/archive/refs/tags/v${version}.tar.gz"
checksum="8621500202803fa23011de50dcec669252b1077d5171783da5e5388e0a6c8cb2"

do_build() {
    export GOFLAGS+=' -buildvcs=false'
    cmake -B build -S . ${configure_args}
    cmake --build build
}

do_install() {
    DESTDIR=${DESTDIR} cmake --install build
    vlicense LICENSE
}
