post_install() {
	vsv beacond
	vlicense LICENSE
	msg_normal "To enable beacon daemon on startup, run:\n"
	msg_normal "\t ln -s /etc/sv/beacond /var/service/\n"
	msg_warn "beacond will NOT start automatically. Enable it manually.\n"
	msg_normal "After linking, try running \'beacon\'\n"
}
