# Template file for 'kf6-attica'
pkgname=kf6-attica
version=6.26.0
revision=1
build_style=cmake
hostmakedepends="extra-cmake-modules qt6-tools qt6-base"
makedepends="qt6-base-devel"
short_desc="Qt library that implements the Open Collaboration Services API"
maintainer="John <me@johnnynator.dev>"
license="LGPL-2.1-or-later"
homepage="https://invent.kde.org/frameworks/attica"
distfiles="${KDE_SITE}/frameworks/${version%.*}/${pkgname#kf6-}-${version}.tar.xz"
checksum=eb2d3d2d8b12c2ab4d192c4ae6f07b0188a40aa002b3056db6369b47b2f9df96


do_check() {
	cd build
	ctest -E "providertest"
}

kf6-attica-devel_package() {
	depends="$makedepends ${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/lib/pkgconfig
		vmove usr/include
		vmove usr/lib/cmake
		vmove "usr/lib/*.so"
	}
}
