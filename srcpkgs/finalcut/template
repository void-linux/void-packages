# Template file for 'finalcut'
pkgname=finalcut
version=0.9.1
revision=1
build_style=gnu-configure
configure_args="--prefix=/usr"
hostmakedepends="automake autoconf libtool pkg-config autoconf-archive"
makedepends="ncurses-devel"
short_desc="C++ class library and widget toolkit for creating TUI programs"
maintainer="Nuggets10 <niccolocal2010@gmail.com>"
license="LGPL-3.0-or-later"
homepage="https://github.com/gansm/finalcut"
distfiles="https://github.com/gansm/finalcut/archive/refs/tags/${version}.tar.gz"
checksum="6593b3c43ba1de98e4e0e3a563dbf9316fade71ef85c82e6b6f086184ec69a56"

pre_configure() {
	autoreconf --install --force
}

finalcut-devel_package() {
	short_desc+=" - development files"
	depends="${sourcepkg}>=${version}_${revision}"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/libfinal.so
		vmove usr/lib/libfinal.a
		vmove usr/lib/pkgconfig
	}
}
