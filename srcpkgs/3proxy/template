post_install() {
	mv "${DESTDIR}/usr/bin/proxy" "${DESTDIR}/usr/bin/3proxy-proxy"
	mv "${DESTDIR}/usr/share/man/man8/proxy.8" "${DESTDIR}/usr/share/man/man8/3proxy-proxy.8"

	vlicense copying
	vsv 3proxy
}
