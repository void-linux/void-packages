# Template file for 'odin'
pkgname=odin
version=2026.05
revision=1
archs="x86_64* i686*"
hostmakedepends="clang llvm"
makedepends="llvm21-devel"
short_desc="General-purpose data-oriented programming language"
maintainer="Eugen Zagorodniy <zag@disroot.org>"
license="Zlib"
homepage="https://odin-lang.org/"
distfiles="https://github.com/odin-lang/Odin/archive/refs/tags/dev-${version//./-}.tar.gz"
checksum="e2c3273728a2c09b581cdf416d850b2388a8f4e66a4357bc737addfd0fa95b75"
nostrip=yes

do_build() {
	vsed -i build_odin.sh -e "s/^\(OS_ARCH=\).*$/\1${XBPS_TARGET_MACHINE}/"
	make release
	make -C vendor/stb/src
	make -C vendor/miniaudio/src
}

do_check() {
	export PATH=.:${PATH}
	./check_all.sh
}

do_install() {
	vlicense LICENSE
	vdoc README.md
	vmkdir usr/lib/${pkgname}
	vcopy odin usr/lib/${pkgname}
	vcopy base usr/lib/${pkgname}
	vcopy core usr/lib/${pkgname}
	vcopy vendor usr/lib/${pkgname}
	vmkdir usr/bin
	ln -s /usr/lib/${pkgname}/odin ${DESTDIR}/usr/bin/odin
}
