pkgname=vesktop
version=1.6.5
revision=1
archs="aarch64 x86_64"
hostmakedepends="pnpm python3 pkg-config"
makedepends="libglib-devel"
depends="alsa-lib gtk+3 nss libnotify libXtst libXScrnSaver webrtc-audio-processing"
short_desc="Custom Discord app with Vencord preinstalled"
maintainer="Artyom Grebentsov <uminekoaa@gmail.com>"
license="GPL-3.0"
homepage="https://vesktop.dev/"
changelog="https://github.com/Vencord/Vesktop/releases/tag/v${version}"
distfiles="https://github.com/Vencord/Vesktop/archive/refs/tags/v${version}.tar.gz"
checksum=4bb9b5e1acaf17a5f145931008fe4015f9b8c1116b769e1a55a68d5483f238fc

do_build() {
	pnpm i --frozen-lockfile
	pnpm buildLibVesktop
	pnpm package:dir
}

do_install() {
	local pkgloc="usr/lib/$pkgname"
	vmkdir ${pkgloc}
	case "$XBPS_TARGET_MACHINE" in
		"aarch64") local distdir="linux-arm64-unpacked" ;;
		"x86_64") local distdir="linux-unpacked" ;;
	esac
	vcopy dist/${distdir}/* ${pkgloc}
	vinstall build/icon.svg 644 usr/share/icons/hicolor/scalable/apps $pkgname.svg
	vinstall $FILESDIR/$pkgname.desktop 644 usr/share/applications
	vmkdir usr/bin
	ln -sfr $DESTDIR/${pkgloc}/$pkgname $DESTDIR/usr/bin/
}

post_install() {
	vlicense LICENSE
}

