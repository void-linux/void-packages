if [ "$XBPS_TARGET_LIBC" = musl ]; then
	export ac_cv_lib_error_at_line=no
	export ac_cv_header_sys_cdefs_h=no

	if [ "$XBPS_TARGET_WORDSIZE" -eq 32 ]; then
		configure_args+=" --disable-year2038"
	fi
fi
