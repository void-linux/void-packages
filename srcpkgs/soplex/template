# Template file for 'soplex'
pkgname=soplex
version=8.0.2
revision=1
build_style=cmake
configure_args="-DMPFR=ON"
hostmakedepends="cmake ninja"
makedepends="libgcc-devel boost-devel tbb-devel gmp-devel zlib-devel mpfr-devel papilo-devel"
checkdepends="lcov"
short_desc="Sequential object-oriented simPlex"
maintainer="Heitor <heitorleite@dcc.ufmg.br>"
license="Apache-2.0"
homepage="https://soplex.zib.de"
distfiles="https://github.com/scipopt/soplex/archive/refs/tags/v${version}.tar.gz"
checksum=9304fd377e506b380c6b234f6aec221bfc8754541e9ad5f5584f5fbb786a8392

if [ -z "$XBPS_CHECK_PKGS" ]; then
	configure_args+=" -DCOVERAGE=OFF"
fi

libsoplex_package() {
	short_desc+=" - runtime library"
	pkg_install() {
		vmove "usr/lib/*.so.*"
	}
}

libsoplex-devel_package() {
	depends="libsoplex>=${version}_${revision} soplex>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/cmake
		vmove "usr/lib/*.a"
		vmove "usr/lib/*.so"
	}
}
