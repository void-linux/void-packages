From b1ccb9932ee3583bb861d499f4ec554d97934ded Mon Sep 17 00:00:00 2001
From: Hofi <hofione@gmail.com>
Date: Mon, 5 Jan 2026 13:38:34 +0100
Subject: [PATCH] afsnmp: seems the latest brew net-snmp version cflags causes
 errors

Signed-off-by: Hofi <hofione@gmail.com>
---
 modules/afsnmp/Makefile.am    | 1 -
 2 files changed, 3 deletions(-)

diff --git a/modules/afsnmp/Makefile.am b/modules/afsnmp/Makefile.am
index ac98cf61972..dabe140be27 100644
--- a/modules/afsnmp/Makefile.am
+++ b/modules/afsnmp/Makefile.am
@@ -19,7 +19,6 @@ modules_afsnmp_libafsnmp_la_SOURCES	=	\
 
 modules_afsnmp_libafsnmp_la_CPPFLAGS	=	\
 	$(AM_CPPFLAGS)					\
-	$(NETSNMP_CFLAGS)	\
 	-I$(top_srcdir)/modules/afsnmp		\
 	-I$(top_builddir)/modules/afsnmp
 
