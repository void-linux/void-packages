From 263829a19beae5bfec52168373b69a11cd0aa07c Mon Sep 17 00:00:00 2001
From: sn0w <me@sn0w.cx>
Date: Sat, 22 Feb 2025 21:35:24 +0100
Subject: [PATCH 1/2] govet: skip fieldalignment test on 32bit platforms

---
 pkg/golinters/govet/testdata/govet_fieldalignment.go | 1 +
 test/testshared/directives.go                        | 4 ++++
 2 files changed, 5 insertions(+)

diff --git a/pkg/golinters/govet/testdata/govet_fieldalignment.go b/pkg/golinters/govet/testdata/govet_fieldalignment.go
index e29be101..315ab8a1 100644
--- a/pkg/golinters/govet/testdata/govet_fieldalignment.go
+++ b/pkg/golinters/govet/testdata/govet_fieldalignment.go
@@ -1,5 +1,6 @@
+//go:build !(386 || arm || mips || mipsle)
 //golangcitest:args -Egovet
 //golangcitest:config_path testdata/govet_fieldalignment.yml
 package testdata
 
 type gvfaGood struct {
diff --git a/test/testshared/directives.go b/test/testshared/directives.go
index 2881816b..c3f97afc 100644
--- a/test/testshared/directives.go
+++ b/test/testshared/directives.go
@@ -134,10 +134,14 @@ func evaluateBuildTags(tb testing.TB, line string) bool {
 	return parse.Eval(func(tag string) bool {
 		if tag == runtime.GOOS {
 			return true
 		}
 
+		if tag == runtime.GOARCH {
+			return true
+		}
+
 		if buildTagGoVersion(tag) {
 			return true
 		}
 
 		return false
