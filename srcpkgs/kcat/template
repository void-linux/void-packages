# Template file for 'kcat'
pkgname=kcat
version=1.7.1
revision=1
build_style=configure
makedepends="librdkafka-devel"
short_desc="Command line Apache Kafka producer and consumer"
maintainer="Orphaned <orphan@voidlinux.org>"
license="BSD-2-Clause"
homepage="https://github.com/edenhill/kcat"
changelog="https://raw.githubusercontent.com/edenhill/kcat/master/CHANGELOG.md"
distfiles="${homepage}/archive/${version}.tar.gz"
checksum=a2daa5a14c43522153241a1d8a7ba3a51aa2a76f53a957907e18c79beec4a3a3

do_install() {
	vman kcat.1
	vbin kcat
	vlicense LICENSE
}

kafkacat_package() {
	depends="${sourcepkg}>=${version}_${revision}"
	short_desc+=" (transitional dummy package)"
	metapackage=yes
}
