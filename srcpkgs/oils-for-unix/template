# Template file for 'oils-for-unix'
pkgname=oils-for-unix
version=0.23.0
revision=1
build_style=gnu-configure
configure_args="$(vopt_with readline) --readline=$XBPS_CROSS_BASE"
makedepends="$(vopt_if readline readline-devel)"
short_desc="New unix shell with JSON-compatible structured data"
maintainer="meator <meator.dev@gmail.com>"
license="Apache-2.0"
homepage="https://www.oilshell.org/"
distfiles="https://www.oilshell.org/download/oils-for-unix-${version}.tar.gz"
checksum=c9d35ca78b4a08eeafac8bc6439e2bb40bccd3370db2226487faed6348a17521
register_shell="/usr/bin/osh /usr/bin/ysh"
conflicts="oil"

build_options="readline"
build_options_default="readline"

do_build() {
	# OILS_PARALLEL_BUILD affects only the first (largest) TU,
	# everything else is build sequentially.
	if [ "$XBPS_MAKEJOBS" -eq 1 ]; then
		export OILS_PARALLEL_BUILD=0
	else
		export OILS_PARALLEL_BUILD=1
	fi
	_build/oils.sh "$CXX"
}

do_install() {
	# Upstream does contain an install script, but it doesn't work
	# without patches and it's simpler to install the package manually.
	vbin _bin/$CXX-opt-sh/oils-for-unix
	ln -s /usr/bin/oils-for-unix ${DESTDIR}/usr/bin/osh
	ln -s /usr/bin/oils-for-unix ${DESTDIR}/usr/bin/ysh
	vman doc/osh.1
}
