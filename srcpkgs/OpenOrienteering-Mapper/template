post_patch() {
	vsed -i -e '/add_subdirectory.*doc\/licensing/d' CMakeLists.txt
	vsed -i -e '\|#include <private/qcore_unix_p.h>|d' \
		src/printsupport/qt-5.12.4/printengine_advanced_pdf.cpp
}

do_check() {
	cd build
	ctest
}
