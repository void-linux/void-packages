# Template file for 'newsflash'
pkgname=newsflash
version=5.0.0
revision=1
build_style=meson
build_helper=rust
_llvmver=22
hostmakedepends="cargo pkg-config glib-devel sqlite-devel gettext-devel
 desktop-file-utils gtk4-update-icon-cache blueprint-compiler rust-bindgen clang${_llvmver}"
makedepends="rust-std libwebkitgtk60-devel libadwaita-devel openssl-devel clapper-devel libxml2-devel
 gtksourceview5-devel"
short_desc="RSS feed reader that supports various web based services"
maintainer="Orphaned <orphan@voidlinux.org>"
license="GPL-3.0-or-later"
homepage="https://gitlab.com/news-flash/news_flash_gtk"
distfiles="https://gitlab.com/news-flash/news_flash_gtk/-/archive/v.${version}/news_flash_gtk-v.${version}.tar.gz"
checksum=c424c5d2385716bece4bf5881eba88b18ff6a18cff6c1aad370e5232eecfd871

post_patch() {
	if [ -n "$CROSS_BUILD" ]; then
		vsed -i src/meson.build \
			-e "s%rust_target /%'${RUST_TARGET}' / rust_target /%"
	fi
	vsed -i meson.build -e "s;'0\.0\.0';'${version}';"
}

pre_build() {
	if [ "$CROSS_BUILD" ]; then
		export GI_TYPELIB_PATH="${XBPS_CROSS_BASE}/usr/lib/girepository-1.0"
	fi
}
