post_extract() {
	vsrcextract ${pkgname}-${version}.tar.gz
	vsrcextract -C third-party/Simple-Web-Server Simple-Web-Server.tar.gz
	vsrcextract -C third-party/TPCircularBuffer TPCircularBuffer.tar.gz
