# Template file for 'steamdeck-dkms'
pkgname=steamdeck-dkms
version=6.8.12.valve2.2
revision=1
_tag=99737c4a54e3140c7148014980c0905d0868d7ba
short_desc="Steam Deck EC sensors driver"
maintainer="Yurei TZK <me@yureitzk.com>"
license="GPL-2.0-only"
homepage="https://github.com/firlin123/steamdeck-dkms"
distfiles="https://github.com/firlin123/steamdeck-dkms/archive/${_tag}.tar.gz"
checksum="72e3914703a2183b22b52adc0013667f0c0261a05986a1837c3940eb9013c894"

dkms_modules="steamdeck ${version}"
triggers="dkms initramfs-regenerate"
depends="dkms"

do_install() {
	vmkdir usr/src/steamdeck-${version}
	for f in Makefile *.c *.h; do
		[ -f "${wrksrc}/${f}" ] || continue
		vcopy "${wrksrc}/${f}" usr/src/steamdeck-${version}
	done
	sed "s/#MODULE_VERSION#/${version}/" \
		${wrksrc}/debian/steamdeck-dkms.dkms > ${DESTDIR}/usr/src/steamdeck-${version}/dkms.conf
	vinstall ${wrksrc}/usr/share/initramfs-tools/modules.d/steamdeck-dkms.conf \
		644 etc/modules-load.d steamdeck.conf
}
