	configure_args="-Dman=false"
else
	hostmakedepends+=" help2man"
fi

# Remove hard-dep on crontab, leave up to user to decide
post_extract() {
	vsed -i src/Core/Main.vala -e '/dependencies/s:"crontab",::'
}
