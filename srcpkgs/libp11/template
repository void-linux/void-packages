# Template file for 'libp11'
pkgname=libp11
version=0.4.18
revision=1
build_style=gnu-configure
hostmakedepends="pkg-config"
makedepends="openssl-devel p11-kit-devel"
short_desc=" PKCS#11 wrapper library"
maintainer="Đoàn Trần Công Danh <congdanhqx@gmail.com>"
license="LGPL-2.1-or-later"
homepage="https://github.com/OpenSC/libp11"
distfiles="https://github.com/OpenSC/libp11/releases/download/libp11-${version}/libp11-${version}.tar.gz"
checksum=9292de67ca73aba1deacf577c9086b595765f36ef47712cfeb49fa31f6e772fb

libp11-devel_package() {
	depends="${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/share/doc
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove "usr/lib/*.a"
		vmove "usr/lib/*.so"
	}
}
