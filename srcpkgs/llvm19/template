		depends+=" clang19-devel>=${version}_${revision} "
	fi
	if [ "$build_option_llvm_spirv" ]; then
		depends+=" SPIRV-LLVM-Translator19-devel>=${version}_${revision} "
	fi
	pkg_install() {
		vmove ${_llvm_libdir}/libLLVM.so
