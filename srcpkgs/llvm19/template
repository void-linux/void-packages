lld19_package() {
	lib32disabled=yes
	conflicts="lld18>=0 lld17>=0 lld15>=0"
	short_desc+=" - linker"
	homepage="https://lld.llvm.org"
	pkg_install() {
		vmove usr/bin/lld
		vmove usr/bin/lld-link
		vmove usr/bin/ld.lld
		vmove usr/bin/ld64.lld
		vmove usr/bin/wasm-ld
	}
}

