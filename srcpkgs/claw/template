# Template file for 'claw'
pkgname=claw
version=1.5.2
revision=2
build_style=cargo
make_build_args="--manifest-path src-tauri/Cargo.toml"
make_check_args="--manifest-path src-tauri/Cargo.toml"
hostmakedepends="nodejs pnpm pkg-config"
makedepends="gtk+3-devel libwebkit2gtk41-devel libsoup3-devel libayatana-appindicator-devel"
depends="gtk+3 libwebkit2gtk41 libayatana-appindicator"
short_desc="Crustacean powered clipboard manager for X11 and Wayland"
maintainer="Dustin Pilgrim <dustin.pilgrim1997@gmail.com>"
license="MIT"
homepage="https://github.com/saltnpepper97/claw"
distfiles="${homepage}/archive/refs/tags/v${version}.tar.gz"
checksum=a551ee03413c078c71b5b771ce0152685a97f1f5da685beeef043e3ebf493858
nocross="Uses host nodejs/pnpm to build frontend assets"

pre_build() {
	pnpm install --frozen-lockfile
	pnpm run build
}

do_install() {
	vbin src-tauri/target/${RUST_TARGET}/release/claw
	vmkdir usr/share/applications
	cat > ${DESTDIR}/usr/share/applications/claw.desktop <<- 'EOF'
	[Desktop Entry]
	Version=1.0
	Type=Application
	Name=Claw
	Comment=Crustacean powered clipboard manager for X11 and Wayland
	Exec=claw
	Icon=claw
	Terminal=false
	Categories=Utility;
	StartupNotify=true
	EOF
	vinstall src-tauri/icons/128x128.png 644 usr/share/pixmaps claw.png
	vmkdir usr/share/doc/${pkgname}
	vcopy examples/* usr/share/doc/${pkgname}
	vdoc README.md
	vlicense LICENSE
}
