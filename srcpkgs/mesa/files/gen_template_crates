#!/bin/bash

_distfiles=
_checksum=
_skip_extraction=
_crates=

while read -r _wrapfile; do
	_rows=$(grep '=' "$_wrapfile" | tr -d " \t\$\`")

	#./subprojects/syn-2-rs.wrap
	# directory=syn-2.0.87
	# source_url=https://crates.io/api/v1/crates/syn/2.0.87/download
	# source_filename=syn-2.0.87.tar.gz
	# source_hash=25aa4ce346d03a6dcd68dd8b4010bcb74e54e62c90c573f394c46eae99aba32d
	# patch_directory=syn-2-rs

	_source_url=$(grep '^source_url=' <<< "$_rows"); _source_url=${_source_url#*=}
	[ -n "${_source_url}" ] || continue

	_source_filename=$(grep '^source_filename=' <<< "$_rows"); _source_filename=${_source_filename#*=}
	_source_hash=$(grep '^source_hash=' <<< "$_rows"); _source_hash=${_source_hash#*=}
	_directory=$(grep '^directory=' <<< "$_rows"); _directory=${_directory#*=}
	_patch_directory=$(grep '^patch_directory=' <<< "$_rows"); _patch_directory=${_patch_directory#*=}

	_distfiles+=$'\n'" ${_source_url}>${_source_filename}"
	_checksum+=$'\n'" $_source_hash"
	_skip_extraction+=$'\n'" ${_source_filename}"

	#_subname=$(sed -r 's|.*crates/([^/]+)/([0-9.]+)/download|\1|' <<< "$_source_url")
	#_subversion=$(sed -r 's|.*crates/([^/]+)/([0-9.]+)/download|\2|' <<< "$_source_url")

	_crates+=$'\n'"	_prepare_subproject '${_source_filename}' '${_directory}' '${_patch_directory}'"
done < <(find ./subprojects -maxdepth 1 -type f -name '*-rs.wrap' | sort)

cat <<!
distfiles+="$_distfiles"
checksum+="$_checksum"
skip_extraction+="$_skip_extraction"

_prepare_subproject() {
	local source_filename=\$1
	local directory=\$2
	local patch_directory=\$3

	vsrcextract -C "subprojects/\${directory}" "\${source_filename}"
	cp -t "subprojects/\${directory}" "subprojects/packagefiles/\${patch_directory}/meson.build"
}

_post_extract_crates() {
${_crates}
}
!
