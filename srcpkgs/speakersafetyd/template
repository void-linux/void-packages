post_install() {
	# can use make install-data if don't mind about systemd
	vinstall 95-speakersafetyd.rules 644 usr/lib/udev/rules.d/

	for f in conf/apple/*; do
		vinstall "$f" 644 usr/share/speakersafetyd/apple
	done

	vlicense LICENSE
	vsv speakersafetyd
}
