make_dirs="/etc/${pkgname} 0750 _shadowsocks _shadowsocks"

post_install() {
	vlicense LICENSE
	vsv ${pkgname}-server
	vsv ${pkgname}-client
	vsconf examples/config.json
	vsconf examples/config_ext.json
}
