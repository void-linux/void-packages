pkgname=deskgpt
version=20250326
revision=1
wrksrc="DeskGPT-main"
build_style=gnu-makefile
archs="x86_64"
nopie=1
nocheckshlibs=yes

hostmakedepends="git nodejs pnpm"
depends="electron35 nodejs"

short_desc="Desktop ChatGPT client (Electron)"
maintainer="rediskap <jimmbird2068@gmail.com>"
license="GPL-3.0-only"
homepage="https://github.com/0x11c11e/DeskGPT"

distfiles="https://github.com/0x11c11e/DeskGPT/archive/refs/heads/main.tar.gz>deskgpt-${version}.tar.gz"
checksum=1e4d55e9a9a618900dace69e86f571fe6820a24b8ee509ab41b99f43f80a672c


do_build() {
    pnpm install
}


do_install() {

    find node_modules -type f -executable -delete

    vmkdir usr/lib/deskgpt
    vcopy * usr/lib/deskgpt

    vmkdir usr/bin

    cat > ${DESTDIR}/usr/bin/deskgpt << 'EOF'
#!/bin/sh
exec electron35 /usr/lib/deskgpt "$@"
EOF

    chmod +x ${DESTDIR}/usr/bin/deskgpt
}
