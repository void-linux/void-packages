# Template file for 'tlrc'
pkgname=tlrc
version=1.13.0
revision=2
build_style=cargo
short_desc="Official tldr client written in Rust"
maintainer="Simeon Widdis <sawiddis@gmail.com>"
license="MIT"
homepage="https://github.com/tldr-pages/tlrc"
changelog="https://github.com/tldr-pages/tlrc/releases"
distfiles="https://github.com/tldr-pages/tlrc/archive/v${version}.tar.gz"
checksum=be72997481480d66560886d2ff7b1e1d8e086169885d85edee663c9091bd32f3
alternatives="
 tldr:tldr:/usr/bin/tlrc
 tldr:tldr.1:/usr/share/man/man1/tlrc.1
 tldr:tldr.fish:/usr/share/fish/vendor_completions.d/tlrc.fish"

post_install() {
	mv ${DESTDIR}/usr/bin/{tldr,tlrc}
	vcompletion completions/tldr.bash bash
	vcompletion completions/tldr.fish fish
	vcompletion completions/_tldr zsh
	vlicense LICENSE
	vman tldr.1 tlrc.1
}
