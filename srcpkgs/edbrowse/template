make_build_args="QUICKJS_INCLUDE=${XBPS_CROSS_BASE}/usr/include/quickjs QUICKJS_LIB_NAME=quickjs CPPFLAGS+=-DQ_NG=0 CPPFLAGS+=-I${XBPS_CROSS_BASE}/usr/include/quickjs"
hostmakedepends="perl pkg-config"
