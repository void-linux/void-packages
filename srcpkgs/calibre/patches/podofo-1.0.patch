+#else
+    return PdfName::KeyContents;
+#endif
+}
+static inline PdfName podofo_key_filter() {
+#if PODOFO_1_0_OR_LATER
+    return PdfName("Filter");
+#else
+    return PdfName::KeyFilter;
+#endif
+}
