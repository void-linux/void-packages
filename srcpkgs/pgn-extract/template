post_extract() {
	sed -i '/^CC=/d' Makefile
}
do_check() {
	make -C test
}
do_install() {
	vbin build/bin/pgn-extract pgn-extract
	vman pgn-extract.man pgn-extract.1
	vdoc help.html
}
