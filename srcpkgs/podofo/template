# Template file for 'podofo'
pkgname=podofo
version=1.0.3
revision=1
build_style=cmake
configure_args="-DPODOFO_BUILD_STATIC=FALSE
 -DPODOFO_BUILD_UNSUPPORTED_TOOLS=TRUE -DPODOFO_BUILD_TEST=TRUE"
hostmakedepends="pkg-config"
makedepends="fontconfig-devel openssl-devel tiff-devel libxml2-devel zlib-devel
 libjpeg-turbo-devel libpng-devel freetype-devel"
short_desc="Library to work with the PDF file format"
maintainer="Andrea Brancaleoni <abc@pompel.me>"
license="GPL-2.0-or-later, LGPL-2.1-or-later"
homepage="https://github.com/podofo/podofo"
distfiles="https://github.com/podofo/podofo/archive/refs/tags/${version}.tar.gz"
checksum=02815b21a51632c2849d41b067597e9356bbc54bad0efcd84c902b555c203ce7

post_install() {
	local _f
	for _f in man/*.1; do
		vman "$_f"
	done
}

libpodofo_package() {
	replaces="podofo<0.9.3_1"
	short_desc+=" - shared library"
	pkg_install() {
		vmove "usr/lib/*.so.*"
	}
}

libpodofo-devel_package() {
	short_desc+=" - development files"
	depends="libpodofo-${version}_${revision}"
	pkg_install() {
		vmove usr/include
		vmove "usr/lib/*.so"
		vmove usr/lib/pkgconfig
		vmove usr/lib/cmake
	}
}
