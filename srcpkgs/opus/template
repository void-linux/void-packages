# Template file for 'opus'
pkgname=opus
version=1.6
revision=1
build_style=gnu-configure
configure_args="$(vopt_enable dred dred) $(vopt_enable osce osce) $(vopt_enable custom_modes custom-modes)
	$(vopt_enable custom_api opus-custom-api) $(vopt_enable qext qext)"
short_desc="Totally open, royalty-free, highly versatile audio codec"
maintainer="Rutpiv <roger_freitas@live.com>"
license="BSD-3-Clause"
homepage="https://www.opus-codec.org/"
distfiles="https://downloads.xiph.org/releases/opus/opus-${version}.tar.gz"
checksum=b7637334527201fdfd6dd6a02e67aceffb0e5e60155bbd89175647a80301c92c

build_options="dred osce custom_modes custom_api qext"
desc_option_dred="Enable Deep REDundancy (DRED)"
desc_option_osce="Enable Opus Speech Coding Enhancement (OSCE)"
desc_option_custom_modes="Enable custom (non-standard) Opus modes"
desc_option_custom_api="Enable Opus custom API"
desc_option_qext="Enable scalable quality extension (Opus HD)"

build_options_default="dred osce custom_modes custom_api"

post_install() {
	vlicense COPYING
}

opus-devel_package() {
	depends="${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove "usr/lib/*.a"
		vmove "usr/lib/*.so"
		vmove usr/share/aclocal
	}
}
