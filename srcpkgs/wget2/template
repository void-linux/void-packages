# Template file for 'wget2'
pkgname=wget2
version=2.2.0
revision=1
archs="x86_64"
makedepends="
	pandoc
	texinfo
	automake
	autoconf
	autoconf-archive
	libtool
	gettext-devel-tools
	pkgconf
	make
	flex
	rsync
	attr-devel
	python3-devel
	brotli-devel
	gnutls-devel
	nghttp2-devel
	zlib-devel
	lzlib-devel
	libpsl-devel
	libiconv-devel
	libzstd-devel
	libidn2-devel
	$(vopt_if pcre2 pcre2-devel)
	$(vopt_if bzip2 bzip2-devel)
	$(vopt_if lzma liblzma-devel)
"
depends="
	libidn2
	lzlib
	libzstd
	brotli
	zlib
	nghttp2
	libpsl
	gnutls
	glibc
"
short_desc="File and recursive website downloader, successor of GNU Wget"
maintainer="Will Reed <wreedb@disroot.org>"
license="GPL-3.0-or-later"
homepage="https://gitlab.com/gnuwget/wget2"
distfiles="${GNU_SITE}/wget/wget2-${version}.tar.gz"
checksum="2b3b9c85b7fb26d33ca5f41f1f8daca71838d869a19b406063aa5c655294d357"

build_options="pcre2 bzip2 lzma static"
build_options_default="pcre2 bzip2 lzma"

desc_option_pcre2="build with regex support from libpcre2"
desc_option_bzip2="build with bzip2 compression support"
desc_option_lzma="build with lzma compression support"
desc_option_static="build additional static library"

if $(vopt_if pcre2 true false); then depends+=" libpcre2 "; fi
if $(vopt_if lzma true false); then depends+=" liblzma "; fi
if $(vopt_if bzip2 true false); then depends+=" bzip2 "; fi

build_style="gnu-configure"
configure_args="
	--prefix=/usr
	--sysconfdir=/etc
	--enable-shared=yes
	--with-ssl=gnutls
	$(vopt_enable static)
	$(vopt_with lzma)
	$(vopt_with bzip2)
	$(vopt_with pcre2 libpcre2)
"

post_install() {
	rm "${DESTDIR}/usr/bin/wget2_noinstall"
}

wget2-devel_package() {
	short_desc+=" - development files"
	depends="${sourcepkg}>=${version}_${revision}"
	pkg_install() {
		if $(vopt_if static true false); then vmove "usr/lib/*.a"; fi
		vmove usr/include
		vmove usr/lib/*.so
		vmove usr/lib/pkgconfig
	}
}
