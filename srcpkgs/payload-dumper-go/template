# Template file for 'payload-dumper-go'
pkgname=payload-dumper-go
version=1.3.0
revision=1
build_style=go
go_import_path=github.com/ssut/payload-dumper-go
makedepends="liblzma-devel libzstd-devel"
short_desc="Android OTA payload dumper written in Go"
maintainer="Fabian Constantinescu <fabian.constantinescu@protonmail.com>"
license="Apache-2.0"
homepage="https://github.com/ssut/payload-dumper-go"
distfiles="https://github.com/ssut/${pkgname}/archive/refs/tags/${version}.tar.gz"
checksum=d7ba33a80c539674c0b63443b8c6dd9c2040ec996323f38ffe72e024d302eb2d

pre_build() {
	go mod vendor
	vsed -i 's/#cgo LDFLAGS:.*/#cgo LDFLAGS: -lzstd/' \
		vendor/github.com/valyala/gozstd/libzstd_*.go
	cp vendor/github.com/valyala/gozstd/libzstd_linux_amd64.go \
		vendor/github.com/valyala/gozstd/libzstd.go
}
