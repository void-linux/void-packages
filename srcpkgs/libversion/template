# Template file for 'libversion'
pkgname=libversion
version=3.0.4
revision=1
build_style=cmake
short_desc="Advanced version string comparison library"
maintainer="Orphaned <orphan@voidlinux.org>"
license="MIT"
homepage="https://github.com/repology/libversion"
changelog="https://raw.githubusercontent.com/repology/libversion/refs/heads/master/CHANGES.md"
distfiles="https://github.com/repology/libversion/archive/${version}.tar.gz"
checksum=48c2a4a98b6f220dedd535979f1e9ab83f9bf869e06c0f5e7bb1be6d2e662fee

post_install() {
	vlicense COPYING
}

libversion-devel_package() {
	short_desc+=" - development files"
	depends="${sourcepkg}-${version}_${revision}"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove usr/lib/cmake
		vmove "usr/lib/*.so"
		vmove "usr/lib/*.a"
	}
}
