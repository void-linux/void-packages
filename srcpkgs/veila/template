  # Template file for 'veila'
  pkgname=veila
  version=0.1.5
  revision=1
  build_style=cargo
  # build_wrksrc="Veila"
  hostmakedepends="pkg-config"
  makedepends="pam-devel wayland-devel libxkbcommon-devel"
  short_desc="Secure, elegant, and fast Wayland screen locker"
  maintainer="Nauris Steins <me@naurissteins.com>"
  license="GPL-3.0-or-later"
  homepage="https://github.com/naurissteins/Veila"
  changelog="https://github.com/naurissteins/Veila/releases"
  distfiles="https://github.com/naurissteins/Veila/archive/refs/tags/${version}.tar.gz"
  checksum=8230ad1c9fb374ff13b69468754cc49ba6aaf6d2ab613b8e87e78e437f2fc2d3

  do_build() {
        cargo build --locked --release --workspace
  }

  do_install() {
        vbin target/release/veila
        vbin target/release/veilad
        vbin target/release/veila-curtain

        vmkdir usr/share/veila
        vcopy assets/bg usr/share/veila
        vcopy assets/fonts usr/share/veila
        vcopy assets/icons usr/share/veila
        vcopy assets/themes usr/share/veila

        vmkdir etc/pam.d
        vinstall ${FILESDIR}/veila.pam 644 etc/pam.d veila

        vlicense LICENSE
        vdoc README.md
  }

