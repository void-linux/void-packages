Patch-Source: https://www.linuxfromscratch.org/patches/blfs/svn/firefox-140.9.0esr-llvm_22-1.patch
From 47df0945909c669c987b8835b7324cfa51e33f40 Mon Sep 17 00:00:00 2001
From: Antoine Martin <dev@ayakael.net>
Date: Sat, 4 Apr 2026 16:55:12 -0400
Subject: [PATCH 2/2] llvm 22 fixes

Submitted by:            Xi Ruoyao <xry111@xry111.site>
Date:                    2026-03-07
Initial Package Version: 140.8.0
Upstream Status:         Applied in rust-bindgen and skcms but not applied
                         for Firefox yet.  Reported at firefix PR 1977771
                         comment 2.
Origin:                  rust-bindgen and skcms upstream repo;
                         the test suite change and two redundant changes
                         cancelling each other out are dropped from the
                         rust-bindgen change; the file paths are manually
                         edited for the firefox source tree.
Description:             Allow building firefox with LLVM (clang) 22.
---
 gfx/skia/skia/modules/skcms/src/Transform_inl.h |  4 ++--
 third_party/rust/bindgen/clang.rs               | 10 +++++-----
 2 files changed, 7 insertions(+), 7 deletions(-)

diff --git a/gfx/skia/skia/modules/skcms/src/Transform_inl.h b/gfx/skia/skia/modules/skcms/src/Transform_inl.h
index bc10e7d..99faf25 100644
--- a/gfx/skia/skia/modules/skcms/src/Transform_inl.h
+++ b/gfx/skia/skia/modules/skcms/src/Transform_inl.h
@@ -156,8 +156,8 @@ SI F F_from_Half(U16 half) {
 #elif defined(USING_AVX512F)
     return (F)_mm512_cvtph_ps((__m256i)half);
 #elif defined(USING_AVX_F16C)
-    typedef int16_t __attribute__((vector_size(16))) I16;
-    return __builtin_ia32_vcvtph2ps256((I16)half);
+    typedef _Float16 __attribute__((vector_size(16))) F16;
+    return __builtin_convertvector((F16)half, F);
 #else
     U32 wide = cast<U32>(half);
     // A half is 1-5-10 sign-exponent-mantissa, with 15 exponent bias.
diff --git a/third_party/rust/bindgen/clang.rs b/third_party/rust/bindgen/clang.rs
index 19f3e70..c7e1531 100644
--- a/third_party/rust/bindgen/clang.rs
+++ b/third_party/rust/bindgen/clang.rs
@@ -1210,11 +1210,11 @@ impl Type {
 
     /// Get a cursor pointing to this type's declaration.
     pub(crate) fn declaration(&self) -> Cursor {
-        unsafe {
-            Cursor {
-                x: clang_getTypeDeclaration(self.x),
-            }
-        }
+        let decl = Cursor {
+            x: unsafe { clang_getTypeDeclaration(self.x) },
+        };
+        // Prior to clang 22, the declaration pointed to the definition.
+        decl.definition().unwrap_or(decl)
     }
 
     /// Get the canonical declaration of this type, if it is available.
-- 
