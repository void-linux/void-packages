post_install() {
	for shell in bash zsh fish; do
		_TOOT_COMPLETE=${shell}_source PYTHONPATH="${DESTDIR}/${py3_sitelib}" \
			$DESTDIR/usr/bin/toot > completion.$shell
		vcompletion completion.$shell $shell
	done
}
