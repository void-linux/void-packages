pre_configure() {
	rmdir ext/Dirent
	rmdir ext/ImGuiColorTextEdit
	rmdir ext/glm
	rmdir ext/imgui
	rmdir ext/stb
	rmdir ext/tfd
	rmdir ext/tinyxml2

