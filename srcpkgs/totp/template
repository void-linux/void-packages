# Template file for 'totp'
pkgname=totp
version=3.0.1
revision=1
hostmakedepends="pkgconf gettext"
short_desc="Generate TOTP codes"
maintainer="Thomas Voss <mail@tvoss.eu>"
license="0BSD"
homepage="https://git.tvoss.eu/totp"
changelog="https://git.tvoss.eu/totp/refs"
distfiles="https://git.tvoss.eu/totp/snapshot/totp-${version}.tar.gz"
checksum=50cf61c0f8d68b49f78ebf2678d47f24fdaf4643e6af662c795c5de2af478b6d

do_build() {
	local prof

	# On aarch64 and x86_64, the dynamic profile exists to perform
	# runtime dispatch of CPU-optimized functions
	case "$XBPS_TARGET_MACHINE" in
	aarch64*|x86_64*)
		prof=dynamic
		;;
	*)
		prof=generic
		;;
	esac
	PREFIX=/usr ./build -a $XBPS_TARGET_MACHINE -p $prof
}

do_install() {
	DESTDIR="$DESTDIR" PREFIX=/usr ./install
	vlicense LICENSE
}

uri2totp_package() {
	short_desc="Generate TOTP codes from URIs"
	depends="totp trurl"

	pkg_install() {
		vmove usr/bin/uri2totp
		vmove usr/share/man/man1/uri2totp.1
	}
}
