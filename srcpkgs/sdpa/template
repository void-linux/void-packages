# Template file for 'sdpa'
pkgname=sdpa
version=7.4.4
revision=1
_commit="19e80bbf0453851520598598308b85b399fde7e5"
build_style=gnu-configure
configure_args="--with-blas=-lopenblas --with-lapack=-lopenblas"
hostmakedepends="gcc-fortran"
makedepends="openblas-devel mumps"
short_desc="Semidefinite Programming Algorithm"
maintainer="Heitor <heitorleite@dcc.ufmg.br>"
license="GPL-3.0-or-later"
homepage="https://github.com/sdpaninf/SDPA"
distfiles="https://github.com/sdpaninf/SDPA/archive/${_commit}.tar.gz"
checksum=d75d67775bb226f4ade52ec8d100473392118dbe35d62d028483fa10433b8a83
build_wrksrc="LP64"

pre_configure() {
	# use system mumps instead of bundled one
	mkdir -p mumps/build/include
	mkdir -p mumps/build/lib
	mkdir -p mumps/build/libseq
	ln -sf "${XBPS_CROSS_BASE}/usr/include/cmumps_c.h" mumps/build/include/
	ln -sf "${XBPS_CROSS_BASE}/usr/include/cmumps_struc.h" mumps/build/include/
	ln -sf "${XBPS_CROSS_BASE}/usr/include/dmumps_c.h" mumps/build/include/
	ln -sf "${XBPS_CROSS_BASE}/usr/include/dmumps_struc.h" mumps/build/include/
	ln -sf "${XBPS_CROSS_BASE}/usr/include/elapse.h" mumps/build/include/
	ln -sf "${XBPS_CROSS_BASE}/usr/include/mpi.h" mumps/build/include/
	ln -sf "${XBPS_CROSS_BASE}/usr/include/mpif.h" mumps/build/include/
	ln -sf "${XBPS_CROSS_BASE}/usr/include/mumps_c_types.h" mumps/build/include/
	ln -sf "${XBPS_CROSS_BASE}/usr/include/mumps_compat.h" mumps/build/include/
	ln -sf "${XBPS_CROSS_BASE}/usr/include/mumps_int_def.h" mumps/build/include/
	ln -sf "${XBPS_CROSS_BASE}/usr/include/smumps_c.h" mumps/build/include/
	ln -sf "${XBPS_CROSS_BASE}/usr/include/smumps_struc.h" mumps/build/include/
	ln -sf "${XBPS_CROSS_BASE}/usr/include/zmumps_c.h" mumps/build/include/
	ln -sf "${XBPS_CROSS_BASE}/usr/include/zmumps_struc.h" mumps/build/include/
	ln -sf "${XBPS_CROSS_BASE}/usr/lib/libcmumps.a" mumps/build/lib/
	ln -sf "${XBPS_CROSS_BASE}/usr/lib/libdmumps.a" mumps/build/lib/
	ln -sf "${XBPS_CROSS_BASE}/usr/lib/libmumps_common.a" mumps/build/lib/
	ln -sf "${XBPS_CROSS_BASE}/usr/lib/libpord.a" mumps/build/lib/
	ln -sf "${XBPS_CROSS_BASE}/usr/lib/libsmumps.a" mumps/build/lib/
	ln -sf "${XBPS_CROSS_BASE}/usr/lib/libzmumps.a" mumps/build/lib/
	ln -sf "${XBPS_CROSS_BASE}/usr/lib/libmpiseq.a" mumps/build/libseq/

	CFLAGS+=" -funroll-all-loops -O2 -m64 -fopenmp -DDIMACS_PRINT -fPIC"
	CXXFLAGS+=" -funroll-all-loops -O2 -m64 -fopenmp -DDIMACS_PRINT -fPIC"
	FFLAGS+=" -funroll-all-loops -O2 -m64 -fopenmp -fallow-argument-mismatch"
}

do_install() {
	vbin sdpa
	vdoc doc/sdpa7-manual.pdf

	vmkdir usr/include/sdpa
	for f in *.h; do
		vinstall "$f" 0644 usr/include/sdpa
	done

	vinstall libsdpa.a 0644 /usr/lib
}

sdpa-devel_package() {
	depends="${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/libsdpa.a
	}
}
