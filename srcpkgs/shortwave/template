post_patch() {
	# remove git dep
	ln -sf /bin/false ${XBPS_WRAPPERDIR}/git

	if [ "$CROSS_BUILD" ]; then
		vsed -i src/meson.build \
			-e "s%rust_target /%'${RUST_TARGET}' / &%"
	fi
}
