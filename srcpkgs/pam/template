# Template file for 'pam'
pkgname=pam
version=1.7.2
revision=1
build_style=meson
configure_args="
 --libdir=/usr/lib --sbindir=/usr/bin --mandir=/usr/share/doc/pam
 --localedir=/usr/share/locale -Dnis=disabled -Daudit=disabled
 -Dselinux=disabled -Dexamples=false -Ddocs=disabled"
hostmakedepends="pkg-config gettext-devel"
makedepends="db-devel"
# version of pam-base that doesn't include removed modules
depends="pam-base>=0.4_1"
checkdepends="pam-base"
short_desc="Flexible mechanism for authenticating users"
maintainer="Érico Nogueira <ericonr@disroot.org>"
license="BSD-3-Clause"
homepage="https://github.com/linux-pam/linux-pam"
changelog="https://raw.githubusercontent.com/linux-pam/linux-pam/master/NEWS"
distfiles="${homepage}/releases/download/v${version}/Linux-PAM-${version}.tar.xz"
checksum=3d86b6383fb5fd9eb9578d2cd47d92801191f4bf3f9bc61419bfefc8aa1e531a

if [ "$XBPS_TARGET_LIBC" = "glibc" ]; then
	makedepends+=" libxcrypt-devel"
	configure_args+=" -Dpam_lastlog=enabled"
elif [ "$XBPS_TARGET_LIBC" = "musl" ]; then
	configure_args+=" -Dpam_lastlog=disabled"
fi

conf_files="
 /etc/environment
 /etc/security/access.conf
 /etc/security/group.conf
 /etc/security/limits.conf
 /etc/security/namespace.conf
 /etc/security/pam_env.conf
 /etc/security/time.conf
 /etc/security/faillock.conf
 /etc/security/namespace.init
 /etc/security/pwhistory.conf"
make_dirs="
 /etc/security/limits.d 0755 root root
 /etc/security/namespace.d 0755 root root"

post_install() {
	mv ${DESTDIR}/usr/share/pam/environment ${DESTDIR}/etc/
	mv ${DESTDIR}/usr/share/pam/security/* ${DESTDIR}/etc/security/

	# Fix unix_chkpwd perms.
	chmod 4755 ${DESTDIR}/usr/bin/unix_chkpwd
	rm -r ${DESTDIR}/usr/lib/systemd
	vlicense COPYING LICENSE
}

pam-devel_package() {
	replaces="pam-libs<1.1.8_8"
	depends="pam-libs>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/*.so
		vmove usr/lib/pkgconfig
	}
}

pam-libs_package() {
	short_desc+=" - runtime libraries"
	pkg_install() {
		vmove "usr/lib/*.so.*"
	}
}

pam-userdb_package() {
	short_desc="PAM module to authenticate against a db database"
	pkg_install() {
		vmove usr/lib/security/pam_userdb.so
	}
}
