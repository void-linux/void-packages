Void uses libcamera by default, which shadows the v4l2 devices
but uses different names and properties, so USBKVM doesn't find them.
Allow gstreamer to use all devices and find the underlying v4l2 device.

--- a/src/usbkvm_application.cpp
+++ b/src/usbkvm_application.cpp
@@ -72,6 +72,7 @@
 
     {
         m_monitor = gst_device_monitor_new();
+        gst_device_monitor_set_show_all_devices(m_monitor, true);
 
         auto bus = gst_device_monitor_get_bus(m_monitor);
         gst_device_monitor_add_filter(m_monitor, "Video/Source", NULL);
