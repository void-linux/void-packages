# Template file for 'vesktop-bin'
pkgname=vesktop-bin
version=1.6.5
revision=1
archs="x86_64"
short_desc="Vesktop is a customizable and privacy friendly Discord desktop app!"
maintainer="synextro <synextro@disroot.org>"
license="GPL-3.0-or-later"
homepage="https://vesktop.dev/"
distfiles="https://github.com/Vencord/Vesktop/releases/download/v${version}/vesktop-${version}.tar.gz"
checksum=a2d1fc9a0c94cd0b47c9ed9240d23d126410894a58f25f9425aad8f02871565d
tags="icon-theme"

do_install() {
	vmkdir usr/bin
	vmkdir opt/Vesktop
	vcopy "*" opt/Vesktop/
	ln -s /opt/Vesktop/vesktop ${DESTDIR}/usr/bin/vesktop

	vinstall ${FILESDIR}/vesktop.desktop 644 usr/share/applications/
	vinstall ${FILESDIR}/vesktop.svg 644 usr/icons/hicolor/scalable/apps/
}
