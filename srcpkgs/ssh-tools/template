# Template file for 'ssh-tools'
pkgname=ssh-tools
version=1.9
revision=1
build_style=go
go_import_path="codeberg.org/vaporup/ssh-tools"
go_package="${go_import_path}/cmd/go/ssh-sig ${go_import_path}/cmd/go/ssh-authorized-keys"
short_desc="Collection of various tools using ssh"
maintainer="Sven Wick <sven.wick@gmx.de>"
license="GPL-3.0-or-later"
homepage="https://codeberg.org/vaporup/ssh-tools"
changelog="https://codeberg.org/vaporup/ssh-tools/src/branch/master/CHANGELOG.md"
distfiles="https://codeberg.org/vaporup/ssh-tools/archive/v${version}.tar.gz"
checksum=6cbfcdb50af3661feb3528132b5321ad5a1fd3f5ac57939c9f9ea8e3337b9892

post_install() {

	#
	# Install the script files after building the go binaries
	#

	for dir in cmd/bash/* cmd/perl/*; do
		if [ -d "$dir" ]; then
			local name="${dir##*/}"
			if [ -f "$dir/$name" ]; then
				vbin "$dir/$name"
			fi
		fi
	done

	#
	# Install all manpages
	#

	for manpage in man/*.[1-8]; do
		vman "${manpage}"
	done

	#
	# Install all examples
	#

	for f in examples/*/*; do
		vsconf ${f}
	done

	#
	# README
	#

	vdoc "${FILESDIR}/README.voidlinux"

}
