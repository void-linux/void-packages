# Template file for 'wireshare'
pkgname=wireshare
version=7.0
revision=1
build_style=gnu-makefile
hostmakedepends="openjdk21 gradle"
depends="openjdk21-jre"
short_desc="Peer-to-peer sharing for Gnutella, BitTorrent, magnet, and eD2k"
maintainer="Hermes contributors <noreply@github.com>"
license="GPL-3.0-or-later"
homepage="https://github.com/nmatavka/hermes-wireshare"
distfiles="https://github.com/nmatavka/hermes-wireshare/releases/download/release/7.0/WireShare-7.0-source.tar.gz"
checksum=a2650ca125cf26353dc4968ccce8ea6b05ff14cd648e4242b9c66f674fa8f4b2
archs="x86_64"

do_build() {
	./gradlew --no-daemon wireShareJar
}

do_install() {
	vmkdir usr/bin usr/share/wireshare usr/lib/wireshare
	vinstall packaging/common/launchers/WireShare 755 usr/bin WireShare
	vinstall WireShare.jar 644 usr/share/wireshare WireShare.jar
	vinstall packaging/common/app/cx.hermes.WireShare.desktop 644 usr/share/applications cx.hermes.WireShare.desktop
	vinstall packaging/common/app/cx.hermes.WireShare.metainfo.xml 644 usr/share/metainfo cx.hermes.WireShare.metainfo.xml
	vcopy packaging/common/icons usr/share
	vinstall nativelibs/linux/libjdic.so 644 usr/lib/wireshare libjdic.so
	vinstall nativelibs/linux/libtorrent-wrapper.so 644 usr/lib/wireshare libtorrent-wrapper.so
	vinstall nativelibs/linux/libtorrent-wrapper64.so 644 usr/lib/wireshare libtorrent-wrapper64.so
	vinstall nativelibs/linux/libtray.so 644 usr/lib/wireshare libtray.so
}
