# Template file for 'libunicode'
pkgname=libunicode
version=0.9.0
revision=1
_ucd_version=17.0.0
build_style=cmake
build_helper="qemu"
configure_args="-DLIBUNICODE_TESTING=OFF"
short_desc="Modern C++20 Unicode library"
maintainer="0x5c <dev@0x5c.io>"
license="Apache-2.0"
homepage="https://github.com/contour-terminal/libunicode"
distfiles="https://github.com/contour-terminal/libunicode/archive/refs/tags/v${version}.tar.gz
 https://www.unicode.org/Public/${_ucd_version}/ucd/UCD.zip>ucd-${_ucd_version}.zip"
checksum="65affc5decf38e5c3e104b021e6d696c2f5bf305f20b475604901682f137e02a
 2066d1909b2ea93916ce092da1c0ee4808ea3ef8407c94b4f14f5b7eb263d28e"
skip_extraction="ucd-${_ucd_version}.zip"

if [ "$XBPS_TARGET_WORDSIZE" -eq 32 ]; then
	configure_args+=" -DLIBUNICODE_SIMD_IMPLEMENTATION=std"
fi

post_extract() {
	vsrccopy "ucd-${_ucd_version}.zip" _ucd
}

libunicode-devel_package() {
	depends="${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove "usr/lib/*.so"
		vmove usr/lib/cmake
	}
}
