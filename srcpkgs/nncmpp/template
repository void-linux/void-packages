post_extract() {
	rm -rf ${wrksrc}/nncmpp/liberty ${wrksrc}/nncmpp/termo
	mv ${wrksrc}/liberty ${wrksrc}/nncmpp/liberty
	mv ${wrksrc}/termo ${wrksrc}/nncmpp/termo
}

post_install() {
	vlicense LICENSE
}
