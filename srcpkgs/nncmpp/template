distfiles="https://git.janouch.name/p/nncmpp/archive/v${version}.tar.gz
 https://git.janouch.name/p/liberty/archive/969a4cfc3ea1c4d7c0327907385fc64906ed5d4c.tar.gz>liberty-${version}.tar.gz
