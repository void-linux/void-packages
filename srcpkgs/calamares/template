# Template file for 'calamares'
pkgname=calamares
version=3.4.2
revision=1
build_style=cmake
configure_args="-DCMAKE_BUILD_TYPE=Release
	-DCMAKE_INSTALL_PREFIX=/usr
	-DINSTALL_CONFIG=ON
	-DINSTALL_POLKIT=ON
	-DWITH_QT6=ON
	-DWITH_QML=ON
	-DWITH_PYTHON=ON
	-DWITH_PYBIND11=ON
	-DBUILD_CRASH_REPORTING=ON
	-DSKIP_MODULES='webview interactiveterminal services-systemd'"
hostmakedepends="git extra-cmake-modules pkg-config"
makedepends="qt6-base-devel qt6-svg-devel qt6-tools-devel qt6-declarative-devel
	yaml-cpp-devel kf6-kcoreaddons-devel polkit-qt6-devel
	python3-devel kf6-ki18n-devel kf6-kwidgetsaddons-devel
	kf6-kservice-devel kf6-kparts-devel libpwquality-devel
	libparted-devel kpmcore-devel libplasma-devel kf6-kpackage-devel
	kf6-kcrash-devel gettext"
depends="qt6-base qt6-svg qt6-declarative yaml-cpp kf6-kcoreaddons
	polkit-qt6 python3 libpwquality libparted kpmcore
	squashfs-tools rsync parted"
short_desc="Distribution-independent installer framework"
maintainer="goldenslumbers <goldenslumbers@purelymail.com>"
license="GPL-3.0-or-later"
homepage="https://calamares.io"
distfiles="https://codeberg.org/Calamares/${pkgname}/releases/download/v${version}/${pkgname}-${version}.tar.gz"
checksum="733bbbb00dc9f84874bd5c22960952f317ea2537565431179fa2152b2fbfdccc"

pre_configure() {
	vsed -i -e "s/desired_size = 512 \* 1024 \* 1024  \# 512MiB/desired_size = 512 \* 1024 \* 1024 \* 4  \# 2048MiB/" src/modules/fstab/main.py
	vsed -i -e 's/"Install configuration files" OFF/"Install configuration files" ON/' CMakeLists.txt
}

post_install() {
	vmkdir etc/polkit-1/rules.d
	vinstall "${FILESDIR}/49-nopasswd-calamares.rules" 644 etc/polkit-1/rules.d
}
