# Template file for 'mumps'
pkgname=mumps
version=5.9.0
revision=1
build_style=gnu-makefile
hostmakedepends="gcc-fortran"
makedepends="openblas-devel"
short_desc="MUltifrontal Massively Parallel sparse direct Solver (Sequential)"
maintainer="Heitor <heitorleite@dcc.ufmg.br>"
license="CECILL-C"
homepage="https://mumps-solver.org"
distfiles="https://mumps-solver.org/MUMPS_${version}.tar.gz"
checksum=02c6efdb91749ec0f82351d40f3f860547272a1eb1d899126a4265b4d6bcc4ca

do_configure() {
	cp Make.inc/Makefile.inc.generic.SEQ Makefile.inc

	sed -i -e "s|LIBBLAS = -lblas|LIBBLAS = -lopenblas|" Makefile.inc
	sed -i -e "s|LAPACK = -llapack|LAPACK = -lopenblas|" Makefile.inc
	sed -i -e "s|CC      = cc|CC      := \$(CC)|" Makefile.inc
	sed -i -e "s|FC      = f90|FC      := \$(FC)|" Makefile.inc
	sed -i -e "s|FL      = f90|FL      := \$(FC)|" Makefile.inc
	sed -i -e "s|OPTF    = -O|OPTF    := \$(FFLAGS) -fPIC -fallow-argument-mismatch|" Makefile.inc
	sed -i -e "s|OPTC    = -O -I.|OPTC    := \$(CFLAGS) -fPIC -I.|" Makefile.inc
}

do_build() {
	make ${makejobs} all
}

do_install() {
	for f in lib/*.a libseq/libmpiseq.a; do
		vinstall "$f" 644 usr/lib
	done

	for f in include/*.h libseq/*.h; do
		vinstall "$f" 644 usr/include
	done
}

post_install() {
	vlicense LICENSE
}
