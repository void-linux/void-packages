system_accounts="_lms"
_lms_homedir="/var/lms"
make_dirs="/var/lms 755 _lms _lms"

post_install() {
	vconf conf/lms.conf
	vmkdir /etc/pam.d
	vcopy conf/pam/* /etc/pam.d
	vsv lms
}
