#! /bin/sh

version=10.8

URL_BASE_PR="https://github.com/sagemath/sage/pull/"
URL_BASE_COMPARE="https://github.com/sagemath/sage/compare/${version}..."

case "$1" in
	-n)  dry=true ;;
esac

# get_pr <PR number> <description> [ext]
get_pr() {
	pr=$1
	desc=$(echo "$2" | sed -e 's/ /_/g')
	ext=${3-diff}
	url="$URL_BASE_PR$pr.$ext"
	out="$pr-$desc.patch"
	echo "curl -sL \"$url\" | filterdiff ... > \"$pr-$desc.patch\""
	if [ -z "$dry" ]; then
		curl -sL "$url" |
			filterdiff -p1 -x build/* |
			sed -e 's|/computational-mathematics-with-sagemath/|/computational_mathematics_with_sagemath/|g' |
			cat > "$pr-$desc.patch"
	fi
}

# run from patches dir
cd $(dirname "$0")

get_pr 40679 "Update to maxima 5.49"
get_pr 42168 "Fix doctest when cypari2 leaked is fixed"
get_pr 42198 "pytest long markers"
