# Template file for 'libfreehand'
pkgname=libfreehand
version=0.1.3
revision=1
build_style=gnu-configure
hostmakedepends="doxygen gperf perl pkg-config"
makedepends="icu-devel lcms2-devel librevenge-devel libcppunit-devel
 boost-headers zlib-devel"
short_desc="Parser for Aldus/Macromedia/Adobe FreeHand documents"
maintainer="Đoàn Trần Công Danh <congdanhqx@gmail.com>"
license="MPL-2.0"
homepage="https://wiki.documentfoundation.org/DLP/Libraries/libfreehand"
distfiles="http://dev-www.libreoffice.org/src/${pkgname}/${pkgname}-${version}.tar.xz"
checksum=a431d78767e5aa27ade7c6d1b7a11a9f1848cb4b9260bf0a6a44689553ecccfe

CXXFLAGS="-Wno-deprecated-copy"

post_install() {
	vlicense COPYING
}

libfreehand-devel_package() {
	short_desc+=" - development files"
	depends="${sourcepkg}>=${version}_${revision} librevenge-devel zlib-devel"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove usr/lib/*.so
	}
}

libfreehand-doc_package() {
	short_desc+=" - documentation"
	depends="${sourcepkg}>=${version}_${revision}"
	pkg_install() {
		vmove usr/share/doc
	}
}
