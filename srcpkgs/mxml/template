# Template file for 'mxml'
pkgname=mxml
version=3.3.1
revision=1
build_style=gnu-configure
configure_args="--enable-static --enable-shared"
short_desc="Minimal XML library"
maintainer="Orphaned <orphan@voidlinux.org>"
license="Apache-2.0"
homepage="https://www.msweet.org/mxml/"
changelog="https://raw.githubusercontent.com/michaelrsweet/mxml/refs/heads/master/CHANGES.md"
distfiles="https://github.com/michaelrsweet/mxml/releases/download/v${version}/mxml-${version}.tar.gz"
checksum=0c663ed1fe393b5619f80101798202eea43534abd7c8aff389022fd8c1dacc32

pre_install() {
	make_install_args+=" DSTROOT=${DESTDIR}"
}

mxml-devel_package() {
	short_desc+=" - development files"
	depends="${sourcepkg}>=${version}_${revision}"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove "usr/lib/*.so"
		vmove "usr/lib/*.a"
	}
}
