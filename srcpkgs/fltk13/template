# Template file for 'fltk13'
pkgname=fltk13
version=1.3.11
revision=1
build_style=cmake
configure_args="
 -DCMAKE_INSTALL_INCLUDEDIR=include/fltk13
 -DFLTK_BUILD_TEST=OFF
 -DOPTION_BUILD_HTML_DOCUMENTATION=OFF
 -DOPTION_BUILD_PDF_DOCUMENTATION=OFF
 -DOPTION_BUILD_SHARED_LIBS=ON
 -DOPTION_CAIRO=ON
 -DOPTION_CAIROEXT=OFF"
hostmakedepends="man-db pkg-config"
makedepends="libjpeg-turbo-devel libpng-devel MesaLib-devel alsa-lib-devel
 freetype-devel libXinerama-devel libXft-devel cairo-devel"
short_desc="Cross-platform C++ GUI toolkit - version 1.3"
maintainer="Emil Tomczyk <emru@emru.xyz>"
license="custom:LGPL-2.0-only WITH FLTK-exception"
homepage="https://www.fltk.org/"
distfiles="https://github.com/fltk/fltk/releases/download/release-${version}/fltk-${version}-source.tar.gz"
checksum=92805abc84505e3e7e27aec775ab0754ecb4182fe2d8ff2a9d568ccdcb2811ac


post_install() {
	vlicense COPYING
}

fltk13-devel_package() {
	depends="${makedepends} fltk13-${version}_${revision}"
	short_desc+=" - development files"
	conflicts="fltk-devel"
	pkg_install() {
		vmove usr/include
		vmove usr/bin/fltk13-config
		vmove usr/bin/fluid13
		vmove usr/lib/*.a
		vmove usr/lib/*.so
		vmove usr/share/cmake
	}
}
